@model GestionFerias_CTPINVU.Models.Juece

@{
    ViewData["Title"] = "Eliminar juez";
    var nombre = Model.Juez?.Persona != null
        ? $"{Model.Juez.Persona.Nombres} {Model.Juez.Persona.Apellidos}"
        : "—";
    var documento = Model.Juez?.Persona?.Documento ?? "—";
    var correo = Model.Juez?.Correo ?? "—";
    var estado = Model.Juez?.Estado ?? "—";
}

<style>
    :root {
        --rojo: #BF1D1A;
        --verde: #6A9A2C;
        --amarillo: #F2B705;
        --naranja: #CB6021;
        --card: #ffffff;
        --line: #e5e5e5;
        --muted: #666;
        --text: #222;
    }

    .marco-ui {
        background: #fff;
        border-radius: 22px;
        box-shadow: 0 10px 30px rgba(0,0,0,.08);
        overflow: hidden;
    }

    .contenido-ui {
        padding: 28px;
        background: #fafafa;
        min-height: 400px;
        border-radius: 22px;
    }

    .tarjeta-eliminar {
        background: var(--card);
        border-radius: 24px;
        box-shadow: 0 6px 20px rgba(0,0,0,.06);
        border: 1px solid var(--line);
        max-width: 560px;
        margin: 0 auto;
        overflow: hidden;
    }

    .tarjeta-eliminar .encabezado {
        background: var(--rojo);
        color: #fff;
        padding: 20px 24px;
        text-align: center;
    }

    .tarjeta-eliminar .encabezado h4 {
        margin: 0;
        font-size: 18px;
    }

    .tarjeta-eliminar .cuerpo {
        padding: 24px;
    }

    .detalle-fila {
        display: flex;
        padding: 10px 0;
        border-bottom: 1px solid var(--line);
        font-size: 14px;
    }

    .detalle-fila:last-child { border-bottom: 0; }

    .detalle-etiqueta {
        font-weight: 600;
        color: var(--muted);
        min-width: 140px;
    }

    .detalle-valor {
        color: var(--text);
    }

    .btn-eliminar-confirm {
        background: var(--rojo);
        border: 1px solid #000;
        border-radius: 16px;
        color: #fff;
        padding: 10px 28px;
        font-size: 14px;
    }

    .btn-cancelar {
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: 16px;
        color: var(--text);
        padding: 10px 28px;
        font-size: 14px;
        text-decoration: none;
    }
</style>

<div class="marco-ui">
    <div class="contenido-ui">

        <div class="mb-4">
            <h2 class="mb-1" style="color:var(--text);">Eliminar juez</h2>
            <p class="mb-0 text-secondary">Confirme que desea eliminar este juez del sistema.</p>
        </div>

        <div class="tarjeta-eliminar">
            <div class="encabezado">
                <h4>⚠ ¿Está seguro de que desea eliminar este juez?</h4>
            </div>
            <div class="cuerpo">
                <div class="detalle-fila">
                    <span class="detalle-etiqueta">Nombre</span>
                    <span class="detalle-valor">@nombre</span>
                </div>
                <div class="detalle-fila">
                    <span class="detalle-etiqueta">Documento</span>
                    <span class="detalle-valor">@documento</span>
                </div>
                <div class="detalle-fila">
                    <span class="detalle-etiqueta">Correo</span>
                    <span class="detalle-valor">@correo</span>
                </div>
                <div class="detalle-fila">
                    <span class="detalle-etiqueta">Estado</span>
                    <span class="detalle-valor">@estado</span>
                </div>

                <div class="d-flex gap-3 justify-content-center mt-4">
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="JuezId" />
                        <button type="submit" class="btn-eliminar-confirm">Eliminar</button>
                    </form>
                    <a asp-action="Index" class="btn-cancelar">Cancelar</a>
                </div>
            </div>
        </div>
    </div>
</div>
