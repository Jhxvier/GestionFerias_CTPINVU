@model GestionFerias_CTPINVU.Models.Usuario

@{
    ViewData["Title"] = "Detalle del Usuario";
}

<div class="container-fluid px-0">
    <div class="d-flex flex-wrap align-items-start justify-content-between gap-2 mb-3">
        <div>
            <h2 class="mb-1">Detalles de Sistema</h2>
            <p class="text-secondary mb-0">Visualización de información de la persona registrada.</p>
        </div>
        <div>
            <a href="javascript:history.back()" class="btn btn-outline-secondary rounded-pill">
                <i class="bi bi-arrow-left"></i> Volver atrás
            </a>
            <a asp-controller="Usuarios" asp-action="Edit" asp-route-id="@Model.UsuarioId" class="btn btn-dark rounded-pill ms-2">
                <i class="bi bi-pencil-square"></i> Editar
            </a>
        </div>
    </div>

    <div class="row justify-content-center g-4">
        <div class="col-12 col-xl-10">
            <div class="card shadow-sm border-0 border-top border-4 rounded-3 p-4 p-md-5" style="border-color: var(--naranja) !important;">
                
                <h4 class="fw-bold mb-4" style="color: var(--text);">Información Base</h4>
                
                <div class="row g-4 mb-4 pb-4 border-bottom">
                    <div class="col-12 col-md-6 col-lg-4">
                        <label class="form-label small text-muted mb-0">Documento</label>
                        <div class="fw-semibold fs-5">@(Model.Persona?.Documento ?? "—")</div>
                    </div>
                    <div class="col-12 col-md-6 col-lg-4">
                        <label class="form-label small text-muted mb-0">Nombres</label>
                        <div class="fw-semibold fs-5">@(Model.Persona?.Nombres ?? "—")</div>
                    </div>
                    <div class="col-12 col-md-6 col-lg-4">
                        <label class="form-label small text-muted mb-0">Apellidos</label>
                        <div class="fw-semibold fs-5">@(Model.Persona?.Apellidos ?? "—")</div>
                    </div>
                    <div class="col-12 col-md-6 col-lg-4">
                        <label class="form-label small text-muted mb-0">Teléfono</label>
                        <div class="fw-semibold fs-5">@(Model.Persona?.Telefono ?? "—")</div>
                    </div>
                    <div class="col-12 col-md-6 col-lg-4">
                        <label class="form-label small text-muted mb-0">Fecha Nacimiento</label>
                        <div class="fw-semibold fs-5">@(Model.Persona?.FechaNacimiento?.ToString("dd/MM/yyyy") ?? "—")</div>
                    </div>
                    <div class="col-12 col-md-6 col-lg-4">
                        <label class="form-label small text-muted mb-0">Nacionalidad</label>
                        <div class="fw-semibold fs-5">@(Model.Persona?.Nacionalidad ?? "—")</div>
                    </div>
                </div>

                <h4 class="fw-bold mb-4" style="color: var(--text);">Credenciales y Seguridad</h4>
                <div class="row g-4 mb-4 pb-4 border-bottom">
                    <div class="col-12 col-md-6">
                        <label class="form-label small text-muted mb-0">Correo Electrónico</label>
                        <div class="fw-semibold fs-5">@Model.Correo</div>
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label small text-muted mb-0">Estado</label>
                        <div>
                            @if (Model.Estado == "Activo")
                            {
                                <span class="badge bg-success bg-opacity-10 text-success border border-success rounded-pill px-3 py-2">ACTIVO</span>
                            }
                            else
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger rounded-pill px-3 py-2">INACTIVO</span>
                            }
                        </div>
                    </div>
                </div>

                <!-- Roles específicos -->
                @if (Model.Estudiante != null || Model.Tutore != null || Model.Juece != null)
                {
                    <h4 class="fw-bold mb-4" style="color: var(--text);">Ficha de Participación</h4>
                    <div class="row g-4">
                        @if (Model.Estudiante != null)
                        {
                            <div class="col-12 col-md-6">
                                <label class="form-label small text-muted mb-0">Rol</label>
                                <div class="fw-semibold fs-5"><i class="bi bi-mortarboard me-2 text-primary"></i>Estudiante</div>
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label small text-muted mb-0">Grado Académico</label>
                                <div class="fw-semibold fs-5">@(Model.Estudiante.Grado ?? "—")</div>
                            </div>
                        }
                        
                        @if (Model.Tutore != null)
                        {
                            <div class="col-12 col-md-6">
                                <label class="form-label small text-muted mb-0">Rol</label>
                                <div class="fw-semibold fs-5"><i class="bi bi-person-video3 me-2 text-primary"></i>Tutor</div>
                            </div>
                            <div class="col-12 col-md-6">
                                <label class="form-label small text-muted mb-0">Especialidad</label>
                                <div class="fw-semibold fs-5">@(Model.Tutore.Especialidad ?? "—")</div>
                            </div>
                        }

                        @if (Model.Juece != null)
                        {
                            <div class="col-12">
                                <label class="form-label small text-muted mb-0">Rol</label>
                                <div class="fw-semibold fs-5"><i class="bi bi-person-check me-2 text-success"></i>Juez de Ferias</div>
                            </div>
                        }
                    </div>
                }

            </div>
        </div>
    </div>
</div>
