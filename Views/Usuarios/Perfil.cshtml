@model GestionFerias_CTPINVU.ViewModels.PerfilViewModel

@{
    ViewData["Title"] = "Usuarios — Crear / Editar";
}

<style>
    :root {
        --rojo: #BF1D1A;
        --verde: #6A9A2C;
        --amarillo: #F2B705;
        --naranja: #CB6021;
        --line: #e5e5e5;
        --muted: #666;
    }

    .card-top {
        background: var(--verde);
        color: #fff;
        border-top-left-radius: 1rem;
        border-top-right-radius: 1rem;
    }

    .mode-pill {
        background: rgba(255,255,255,.18);
        border: 1px solid rgba(255,255,255,.35);
        padding: .35rem .6rem;
        border-radius: 999px;
        font-size: .85rem;
        white-space: nowrap;
    }

    .section-box {
        border: 1px solid var(--line);
        border-radius: 1rem;
        padding: 1rem;
        background: #fff;
    }

    .section-title {
        color: var(--naranja);
        font-weight: 500;
        font-size: .95rem;
        margin: 0 0 .75rem 0;
    }

    .note {
        color: var(--muted);
        font-size: .85rem;
    }

    /* ROL Y MODO SE MANEJAN POR CSS DINÁMICO DESDE SERVIDOR O JS */
    .only-admin, .only-coord, .admin-or-coord {
        display: none;
    }

    body.role-admin .only-admin {
        display: block;
    }

    body.role-coord .only-coord {
        display: block;
    }

    body.role-admin .admin-or-coord,
    body.role-coord .admin-or-coord {
        display: block;
    }

    .only-create {
        display: none;
    }

    .only-edit {
        display: none;
    }

    body.mode-create .only-create {
        display: block;
    }

    body.mode-edit .only-edit {
        display: block;
    }

    .field-email-admin {
        display: none;
    }

    body.role-admin.mode-create .field-email-admin,
    body.role-admin.mode-edit .field-email-admin {
        display: block;
    }

    .field-email-coord {
        display: none;
    }

    body.role-coord.mode-edit .field-email-coord {
        display: block;
    }

    .field-temp-pass {
        display: none;
    }

    body.role-admin.mode-create .field-temp-pass {
        display: block;
    }

    .section-role-create {
        display: none;
    }

    body.role-admin.mode-create .section-role-create {
        display: block;
    }

    .section-reset {
        display: none;
    }

    body.role-admin.mode-edit .section-reset {
        display: block;
    }

    .section-change-pass {
        display: none;
    }

    body.role-admin.mode-edit .section-change-pass {
        display: block;
    }

    .extra-estudiante, .extra-tutor, .extra-juez, .extra-coord {
        display: none;
    }

    body.selected-estudiante .extra-estudiante {
        display: block;
    }

    body.selected-tutor .extra-tutor {
        display: block;
    }

    body.selected-juez .extra-juez {
        display: block;
    }

    body.selected-coord .extra-coord {
        display: block;
    }

    body.show-all-specific .extra-estudiante,
    body.show-all-specific .extra-tutor,
    body.show-all-specific .extra-juez,
    body.show-all-specific .extra-coord {
        display: block;
    }
</style>

<div class="container-fluid px-3 px-md-4">
    <div class="d-flex flex-wrap align-items-start align-items-md-center justify-content-between gap-2 mt-3">
        <div>
            <h2 class="mb-1">Usuarios — @(Model.Modo == "create" ? "Crear nuevo" : "Editar información")</h2>
            <p class="mb-0 text-muted">Formulario para crear/editar usuarios.</p>
        </div>
    </div>

    <div class="card shadow-sm border-0 mt-3">
        <div class="card-top px-3 py-3 d-flex flex-wrap align-items-center justify-content-between gap-2">
            <div class="fw-semibold">Formulario de usuario</div>
            <div class="mode-pill">Modo: @(Model.Modo == "create" ? "Crear" : "Editar")</div>
        </div>

        <div class="card-body bg-light">

            <form asp-action="GuardarPerfil" method="post" class="needs-validation" novalidate>
                <input type="hidden" asp-for="UsuarioId" />
                <input type="hidden" asp-for="PersonaId" />
                <input type="hidden" asp-for="Modo" />
                
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">Por favor, revise los errores abajo antes de continuar.</div>
                }

                <!-- ====== CONFIGURACIÓN INICIAL ====== -->
                <div class="section-box mb-3 @(Model.Modo == "create" ? "section-role-create" : "")">
                    <h3 class="section-title">Configuración de Acceso</h3>

                    <div class="row g-3">
                        <div class="col-12 col-lg-6">
                            <label class="form-label small text-muted">Rol del usuario *</label>
                            <select class="form-select rounded-pill" asp-for="RolSeleccionado" id="rolSelect" required>
                                <option value="">Seleccione</option>
                                <option value="estudiante">Estudiante</option>
                                <option value="tutor">Tutor</option>
                                <option value="juez">Juez</option>
                                <option value="coord">Coordinador</option>
                            </select>
                            <span asp-validation-for="RolSeleccionado" class="text-danger small"></span>
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label small text-muted">Estado</label>
                            <select class="form-select rounded-pill" asp-for="EstadoUsuario">
                                <option value="Activo">Activo</option>
                                <option value="Inactivo">Inactivo</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- ====== DATOS BASE ====== -->
                <div class="section-box mb-3">
                    <h3 class="section-title">Datos base</h3>

                    <div class="row g-3">
                        <div class="col-12 col-lg-6">
                            <label class="form-label small text-muted">Documento *</label>
                            <input class="form-control rounded-pill" type="text" asp-for="Documento" placeholder="Ej: 102340567" required />
                            <span asp-validation-for="Documento" class="text-danger small"></span>
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label small text-muted">Correo / Usuario de Sesión *</label>
                            <input class="form-control rounded-pill" type="email" asp-for="Correo" placeholder="usuario@colegio.edu" required />
                            <span asp-validation-for="Correo" class="text-danger small"></span>
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label small text-muted">Nombres *</label>
                            <input class="form-control rounded-pill" type="text" asp-for="Nombres" required />
                            <span asp-validation-for="Nombres" class="text-danger small"></span>
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label small text-muted">Apellidos *</label>
                            <input class="form-control rounded-pill" type="text" asp-for="Apellidos" required />
                            <span asp-validation-for="Apellidos" class="text-danger small"></span>
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label small text-muted">Teléfono</label>
                            <input class="form-control rounded-pill" type="text" asp-for="Telefono" />
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label small text-muted">Edad</label>
                            <input class="form-control rounded-pill" type="number" min="0" asp-for="Edad" />
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label small text-muted">Sexo</label>
                            <select class="form-select rounded-pill" asp-for="Sexo">
                                <option value="">Seleccione</option>
                                <option value="Masculino">Masculino</option>
                                <option value="Femenino">Femenino</option>
                                <option value="Otro">Otro</option>
                                <option value="Prefiero no decir">Prefiero no decir</option>
                            </select>
                        </div>

                        <div class="col-12 col-lg-6">
                            <label class="form-label small text-muted">Nacionalidad</label>
                            <input class="form-control rounded-pill" type="text" asp-for="Nacionalidad" placeholder="Ej: Costarricense" />
                        </div>
                    </div>
                </div>

                <!-- ====== ESPECÍFICOS POR ROL ====== -->
                <div class="section-box mb-3 extra-estudiante">
                    <h3 class="section-title">Datos específicos — Estudiante</h3>
                    <div class="row g-3">
                        <div class="col-12 col-lg-6">
                            <label class="form-label small text-muted">Grado académico</label>
                            <select class="form-select rounded-pill" asp-for="Grado">
                                <option value="">Seleccione</option>
                                <option value="7">7°</option>
                                <option value="8">8°</option>
                                <option value="9">9°</option>
                                <option value="10">10°</option>
                                <option value="11">11°</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="section-box mb-3 extra-tutor">
                    <h3 class="section-title">Datos específicos — Tutor</h3>
                    <div class="row g-3">
                        <div class="col-12 col-lg-6">
                            <label class="form-label small text-muted">Especialidad</label>
                            <select class="form-select rounded-pill" asp-for="Especialidad">
                                <option value="">Seleccione</option>
                                <option value="Ciencias">Ciencias</option>
                                <option value="Tecnología">Tecnología</option>
                                <option value="Matemática">Matemática</option>
                                <option value="Español">Español</option>
                                <option value="Sociales">Sociales</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- ====== SEGURIDAD ====== -->
                <div class="section-box mb-3">
                    <h3 class="section-title">Seguridad</h3>

                    <div class="row g-3 align-items-end">
                        <div class="col-12 col-lg-6">
                            <label class="form-label small text-muted">
                                @(Model.Modo == "create" ? "Asignar contraseña inicial" : "Reasignar contraseña temporal x reset")
                            </label>

                            @{
                                var passPlaceholder = Model.Modo == "edit" ? "Dejar vacío si no se desea cambiar" : "Contraseña";
                                var isRequired = Model.Modo == "create" ? "required" : null;
                            }
                            <input class="form-control rounded-pill" type="text" asp-for="Clave" placeholder="@passPlaceholder" required="@isRequired" />

                            @if (Model.Modo == "create")
                            {
                                <div class="invalid-feedback">Debe asignar una contraseña inicial al crear.</div>
                            }
                        </div>
                    </div>

                    <div class="note mt-2">
                        * Si establece una clave aquí, esta sobrescribirá la anterior y el usuario podrá iniciar sesión con ella.
                    </div>
                </div>

                <hr />

                <div class="d-flex flex-wrap justify-content-end gap-2">
                    <a href="javascript:history.back()" class="btn btn-outline-secondary rounded-pill">Cancelar</a>
                    <button class="btn rounded-pill text-white" type="submit"
                            style="background: var(--rojo); border-color: var(--rojo);">
                        Guardar cambios
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function(){
            // Configurar el tipo de usuario por default para el CSS (Admin temporalmente o quemado arriba)
            document.body.classList.add("role-admin", "mode-@Model.Modo");

            const rolSelect = document.getElementById("rolSelect");
            
            const triggerRolUI = () => {
                document.body.classList.remove("selected-estudiante", "selected-tutor", "selected-juez", "selected-coord");
                const v = (rolSelect.value || "").toLowerCase();
                if(v === "estudiante") document.body.classList.add("selected-estudiante");
                if(v === "tutor") document.body.classList.add("selected-tutor");
                if(v === "juez") document.body.classList.add("selected-juez");
                if(v === "coord") document.body.classList.add("selected-coord");
            };

            if(rolSelect){
                rolSelect.addEventListener("change", triggerRolUI);
                triggerRolUI(); // Run on startup
            }

            // Bootstrap Validation
            const forms = document.querySelectorAll('.needs-validation');
            Array.from(forms).forEach(form => {
                form.addEventListener('submit', event => {
                    if (!form.checkValidity()) {
                        event.preventDefault();
                        event.stopPropagation();
                    }
                    form.classList.add('was-validated');
                }, false);
            });
        })();
    </script>
}