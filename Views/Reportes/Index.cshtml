@{
    ViewData["Title"] = "Reportes";
}

<div class="container-fluid px-0">
    <div class="d-flex flex-wrap align-items-start justify-content-between gap-2 mb-3">
        <div>
            <h2 class="mb-1">Reportes</h2>
            <p class="text-secondary mb-0">
                Generación de reportes en <strong>Excel</strong> o <strong>PDF</strong>.
            </p>
        </div>
    </div>

    <div class="accordion" id="accReportes">

        <!-- 1) Participantes por evento -->
        <div class="accordion-item rounded-4 overflow-hidden border">
            <h2 class="accordion-header" id="h1">
                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#c1" aria-expanded="true" aria-controls="c1">
                    <strong class="me-2">1) Participantes por evento</strong>
                    <span class="text-secondary small d-none d-md-inline">Lista de grupos/estudiantes inscritos en un evento seleccionado</span>
                </button>
            </h2>
            <div id="c1" class="accordion-collapse collapse show" aria-labelledby="h1" data-bs-parent="#accReportes">
                <div class="accordion-body bg-light">
                    <div class="card border-0 rounded-4 shadow-sm">
                        <div class="card-body p-3 p-md-4">
                            <p class="text-secondary mb-3">
                                Seleccione el evento y exporte el listado de participantes aprobados.
                            </p>

                            <div class="row g-3">
                                <div class="col-12 col-lg-7">
                                    <label class="form-label small text-secondary">Evento</label>
                                    <select class="form-select ajax-eventos" id="selectEvt1">
                                        <option value="">Cargando eventos...</option>
                                    </select>
                                </div>

                                <div class="col-12">
                                    <div class="d-flex flex-wrap gap-2 justify-content-end mt-2">
                                        <button class="btn btn-outline-secondary btn-export" data-type="excel" data-report="Participantes" data-target="selectEvt1">
                                            <i class="bi bi-file-earmark-excel me-1"></i> Exportar a Excel
                                        </button>
                                        <button class="btn btn-danger btn-export" data-type="pdf" data-report="Participantes" data-target="selectEvt1">
                                            <i class="bi bi-file-earmark-pdf me-1"></i> Ver/Imprimir PDF
                                        </button>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 2) Resultados por evento -->
        <div class="accordion-item rounded-4 overflow-hidden border mt-3">
            <h2 class="accordion-header" id="h2">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#c2" aria-expanded="false" aria-controls="c2">
                    <strong class="me-2">2) Resultados por evento</strong>
                    <span class="text-secondary small d-none d-md-inline">Ganadores y calificaciones oficiales de un evento</span>
                </button>
            </h2>
            <div id="c2" class="accordion-collapse collapse" aria-labelledby="h2" data-bs-parent="#accReportes">
                <div class="accordion-body bg-light">
                    <div class="card border-0 rounded-4 shadow-sm">
                        <div class="card-body p-3 p-md-4">
                            <p class="text-secondary mb-3">
                                Seleccione el evento y exporte los resultados.
                            </p>

                            <div class="row g-3">
                                <div class="col-12 col-lg-7">
                                    <label class="form-label small text-secondary">Evento</label>
                                    <select class="form-select ajax-eventos" id="selectEvt2">
                                        <option value="">Cargando eventos...</option>
                                    </select>
                                </div>

                                <div class="col-12">
                                    <div class="d-flex flex-wrap gap-2 justify-content-end mt-2">
                                        <button class="btn btn-outline-secondary btn-export" data-type="excel" data-report="Resultados" data-target="selectEvt2">
                                            <i class="bi bi-file-earmark-excel me-1"></i> Exportar a Excel
                                        </button>
                                        <button class="btn btn-danger btn-export" data-type="pdf" data-report="Resultados" data-target="selectEvt2">
                                            <i class="bi bi-file-earmark-pdf me-1"></i> Ver/Imprimir PDF
                                        </button>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 3) Historial de eventos por año -->
        <div class="accordion-item rounded-4 overflow-hidden border mt-3">
            <h2 class="accordion-header" id="h3">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#c3" aria-expanded="false" aria-controls="c3">
                    <strong class="me-2">3) Historial de eventos por año</strong>
                    <span class="text-secondary small d-none d-md-inline">Eventos realizados en un año específico</span>
                </button>
            </h2>
            <div id="c3" class="accordion-collapse collapse" aria-labelledby="h3" data-bs-parent="#accReportes">
                <div class="accordion-body bg-light">
                    <div class="card border-0 rounded-4 shadow-sm">
                        <div class="card-body p-3 p-md-4">
                            <p class="text-secondary mb-3">
                                Indique el año y exporte el historial de eventos realizados.
                            </p>

                            <div class="row g-3">
                                <div class="col-12 col-lg-4">
                                    <label class="form-label small text-secondary">Año</label>
                                    <input class="form-control" id="inputAnio" type="number" min="1990" max="2100" value="@DateTime.Now.Year" />
                                </div>

                                <div class="col-12">
                                    <div class="d-flex flex-wrap gap-2 justify-content-end mt-2">
                                        <button class="btn btn-outline-secondary btn-export" data-type="excel" data-report="HistorialAnio" data-target="inputAnio">
                                            <i class="bi bi-file-earmark-excel me-1"></i> Exportar a Excel
                                        </button>
                                        <button class="btn btn-danger btn-export" data-type="pdf" data-report="HistorialAnio" data-target="inputAnio">
                                            <i class="bi bi-file-earmark-pdf me-1"></i> Ver/Imprimir PDF
                                        </button>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 4) Historial por estudiante -->
        <div class="accordion-item rounded-4 overflow-hidden border mt-3">
            <h2 class="accordion-header" id="h4">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#c4" aria-expanded="false" aria-controls="c4">
                    <strong class="me-2">4) Historial por estudiante</strong>
                    <span class="text-secondary small d-none d-md-inline">Participaciones del estudiante en diferentes ferias</span>
                </button>
            </h2>
            <div id="c4" class="accordion-collapse collapse" aria-labelledby="h4" data-bs-parent="#accReportes">
                <div class="accordion-body bg-light">
                    <div class="card border-0 rounded-4 shadow-sm">
                        <div class="card-body p-3 p-md-4">
                            <p class="text-secondary mb-3">
                                Seleccione un estudiante para generar su historial de participación.
                            </p>

                            <div class="row g-3">
                                <div class="col-12 col-lg-7">
                                    <label class="form-label small text-secondary">Estudiante</label>
                                    <select class="form-select ajax-estudiantes" id="selectEstudiante">
                                        <option value="">Cargando estudiantes...</option>
                                    </select>
                                </div>

                                <div class="col-12">
                                    <div class="d-flex flex-wrap gap-2 justify-content-end mt-2">
                                        <button class="btn btn-outline-secondary btn-export" data-type="excel" data-report="HistorialEstudiante" data-target="selectEstudiante">
                                            <i class="bi bi-file-earmark-excel me-1"></i> Exportar a Excel
                                        </button>
                                        <button class="btn btn-danger btn-export" data-type="pdf" data-report="HistorialEstudiante" data-target="selectEstudiante">
                                            <i class="bi bi-file-earmark-pdf me-1"></i> Ver/Imprimir PDF
                                        </button>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
<script>
    document.addEventListener("DOMContentLoaded", function () {

        // Cargar Eventos
        fetch('/Reportes/GetEventosAJAX')
            .then(res => res.json())
            .then(data => {
                let html = '<option value="">Seleccione un evento</option>';
                data.forEach(evt => html += '<option value="'+evt.id+'">'+evt.texto+'</option>');
                document.querySelectorAll('.ajax-eventos').forEach(el => el.innerHTML = html);
            });

        // Cargar Estudiantes
        fetch('/Reportes/GetEstudiantesAJAX')
            .then(res => res.json())
            .then(data => {
                let html = '<option value="">Seleccione un estudiante</option>';
                data.forEach(est => html += '<option value="'+est.id+'">'+est.texto+'</option>');
                document.querySelectorAll('.ajax-estudiantes').forEach(el => el.innerHTML = html);
            });

        // Manejo de clicks en Exportar
        document.querySelectorAll('.btn-export').forEach(btn => {
            btn.addEventListener('click', function() {
                var tipo = this.getAttribute('data-type');     // 'excel' o 'pdf'
                var reporte = this.getAttribute('data-report');  // 'Participantes', 'Resultados', etc.
                var targetId = this.getAttribute('data-target'); // id of the input/select
                
                var inputEl = document.getElementById(targetId);
                var val = inputEl.value;

                if (!val) {
                    alert("Por favor, seleccione un valor antes de exportar.");
                    return;
                }

                // Armamos la URL construida: Ej. /Reportes/ParticipantesExcel?eventoId=5
                var actionStr = reporte + (tipo === 'excel' ? 'Excel' : 'Pdf');
                
                var paramName = 'eventoId';
                if (reporte === 'HistorialAnio') paramName = 'anio';
                if (reporte === 'HistorialEstudiante') paramName = 'estudianteId';

                var finalUrl = `/Reportes/${actionStr}?${paramName}=${val}`;
                
                // Si es PDF usamos window.open para verlo en otra pestaña e imprimirlo. 
                // Si es Excel, usamos window.location para forzar la descarga de frente.
                if (tipo === 'pdf') {
                    window.open(finalUrl, '_blank');
                } else {
                    window.location.href = finalUrl;
                }
            });
        });

    });
</script>
}