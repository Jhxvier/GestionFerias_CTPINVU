@{
    ViewData["Title"] = "Acceso Denegado";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5 text-center">
    <div class="py-5">
        <i class="bi bi-shield-lock" style="font-size:5rem; color:var(--rojo);"></i>
        <h1 class="mt-3 fw-bold" style="color:var(--rojo);">403 — Acceso Denegado</h1>
        <p class="text-secondary fs-5 mt-2">No tiene permisos suficientes para acceder a esta sección.</p>
        <a href="@Url.Action("Inicio", "Inicio")" class="btn btn-outline-dark rounded-pill mt-3">
            <i class="bi bi-house me-1"></i> Volver al Inicio
        </a>
    </div>
</div>
