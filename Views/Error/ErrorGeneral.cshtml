@model int
@{
    ViewData["Title"] = "Error";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5 text-center">
    <div class="py-5">
        <i class="bi bi-exclamation-circle" style="font-size:5rem; color:var(--naranja);"></i>
        <h1 class="mt-3 fw-bold" style="color:var(--naranja);">Error @Model</h1>
        <p class="text-secondary fs-5 mt-2">Ha ocurrido un error inesperado.</p>
        <a href="@Url.Action("Inicio", "Inicio")" class="btn btn-outline-dark rounded-pill mt-3">
            <i class="bi bi-house me-1"></i> Volver al Inicio
        </a>
    </div>
</div>
