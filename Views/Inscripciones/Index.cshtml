@model GestionFerias_CTPINVU.Models.PaginatedList<GestionFerias_CTPINVU.Models.Inscripcione>

@{
    ViewData["Title"] = "Inscripciones";
    var esAdminOCoord = (bool)(ViewData["EsAdminOCoord"] ?? false);
    var esEstudiante = (bool)(ViewData["EsEstudiante"] ?? false);
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<style>
    :root { --rojo: #BF1D1A; --verde: #6A9A2C; --amarillo: #F2B705; --naranja: #CB6021; --line: #e5e5e5; --muted: #666; }
    .header-ferias { background: linear-gradient(90deg,var(--rojo),var(--naranja)); border-radius: 18px; color: #fff; padding: 18px 22px; box-shadow: 0 10px 30px rgba(0,0,0,.08); }
    .btn-verde { background: var(--verde); color: #fff; border: none; }
    .btn-amarillo { background: var(--amarillo); color: #111; border: none; }
    .btn-naranja { background: var(--naranja); color: #fff; border: none; }
    .btn-rojo { background: var(--rojo); color: #fff; border: none; }
    .card-ferias { border-radius: 20px; border: 1px solid rgba(0,0,0,.06); box-shadow: 0 6px 20px rgba(0,0,0,.06); }
    .badge-estado { border-radius: 999px; padding: 5px 12px; font-weight: 600; font-size: 12px; border: 1px solid rgba(0,0,0,.08); }
    .estado-pendiente { background: #fff8d6; border-color: #f0d36b; color: #7a5d00; }
    .estado-aprobado { background: #eef8e6; border-color: #cfe9b6; color: var(--verde); }
    .tarjeta-est { border: 1px solid var(--line); border-radius: 22px; background: #fff; box-shadow: 0 6px 20px rgba(0,0,0,.06); overflow: hidden; }
    .est-top { background: var(--verde); color: #fff; padding: 14px 16px; display: flex; justify-content: space-between; align-items: center; gap: 10px; flex-wrap: wrap; }
    .est-body { padding: 16px; }
    .kv { display: grid; grid-template-columns: 200px 1fr; gap: 10px; font-size: 13px; margin-bottom: 10px; }
    .kv .k { color: var(--muted); }
</style>

<div class="container-xxl py-4">

    <div class="header-ferias mb-4">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
            <div>
                <h3 class="mb-1">Gestión de inscripciones</h3>
                <div class="opacity-75 small">
                    @if (esAdminOCoord)
                    {
                        <span>Vista completa de todas las inscripciones</span>
                    }
                    else
                    {
                        <span>Mis inscripciones</span>
                    }
                </div>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a asp-action="Create" class="btn btn-verde rounded-pill px-4">
                    <i class="bi bi-plus-circle me-1"></i> Nueva inscripción
                </a>
            </div>
        </div>
    </div>

    @if (esAdminOCoord)
    {
        <div class="card card-ferias mb-4">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Evento</th>
                                <th>Proyecto (Líder)</th>
                                <th>Categoría / Subcategoría</th>
                                <th>Tutor</th>
                                <th class="text-center">Estado</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                var nombreLider = item.LiderUsuario?.Persona != null
                                    ? $"{item.LiderUsuario.Persona.Nombres} {item.LiderUsuario.Persona.Apellidos}"
                                    : $"ID: {item.LiderUsuarioId}";

                                var clasificacion = item.Subcategoria != null
                                    ? $"{item.Subcategoria.Categoria?.Nombre} / {item.Subcategoria.Nombre}"
                                    : "—";

                                var nombreTutor = "— (sin asignar)";
                                if (item.TutorUsuario?.Tutor?.Persona != null)
                                {
                                    var p = item.TutorUsuario.Tutor.Persona;
                                    nombreTutor = $"{p.Nombres} {p.Apellidos}";
                                }

                                var estado = item.EstadoInscripcion ?? "Pendiente";
                                var claseEstado = estado == "Aprobado" ? "estado-aprobado" : "estado-pendiente";

                                <tr>
                                    <td>INS-@item.InscripcionId</td>
                                    <td>@(item.Evento?.NombreEvento ?? "—")</td>
                                    <td>
                                        <div class="fw-semibold">@(item.TituloProyecto ?? "—")</div>
                                        <div class="text-secondary" style="font-size:12px;">@nombreLider</div>
                                    </td>
                                    <td>@clasificacion</td>
                                    <td>@nombreTutor</td>
                                    <td class="text-center">
                                        <span class="badge-estado @claseEstado">@estado</span>
                                    </td>
                                    <td class="text-end">
                                        <div class="d-inline-flex gap-2 flex-wrap justify-content-end">
                                            <a asp-action="Details" asp-route-id="@item.InscripcionId"
                                               class="btn btn-sm btn-amarillo rounded-pill px-3">Ver</a>
                                            <a asp-action="Edit" asp-route-id="@item.InscripcionId"
                                               class="btn btn-sm btn-naranja rounded-pill px-3">Gestionar</a>
                                            <a asp-action="Delete" asp-route-id="@item.InscripcionId"
                                               class="btn btn-sm btn-rojo rounded-pill px-3">Eliminar</a>
                                        </div>
                                    </td>
                                </tr>
                            }

                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="7" class="text-center py-4 text-secondary">
                                        No hay inscripciones registradas.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        @foreach (var item in Model)
        {
            var nombreLider = item.LiderUsuario?.Persona != null
                ? $"{item.LiderUsuario.Persona.Nombres} {item.LiderUsuario.Persona.Apellidos}" : "—";

            var clasificacion = item.Subcategoria != null
                ? $"{item.Subcategoria.Categoria?.Nombre} / {item.Subcategoria.Nombre}" : "—";

            var nombreTutor = "— (sin asignar)";
            if (item.TutorUsuario?.Tutor?.Persona != null)
            {
                var p = item.TutorUsuario.Tutor.Persona;
                nombreTutor = $"{p.Nombres} {p.Apellidos}";
            }

            var estado = item.EstadoInscripcion ?? "Pendiente";
            var claseEstado = estado == "Aprobado" ? "estado-aprobado" : "estado-pendiente";

            var integrantes = item.InscripcionIntegrantes?.Select(ii =>
            {
                var p = ii.EstudianteUsuario?.EstudianteNavigation?.Persona;
                return p != null ? $"{p.Nombres} {p.Apellidos}" : $"ID: {ii.EstudianteUsuarioId}";
            }).ToList() ?? new List<string>();

            <div class="tarjeta-est mb-3">
                <div class="est-top">
                    <div class="fw-semibold">@(item.TituloProyecto ?? "Mi inscripción")</div>
                    <span class="badge-estado @claseEstado" style="border-color:rgba(255,255,255,.35);">@estado</span>
                </div>
                <div class="est-body">
                    <div class="kv"><div class="k">Evento</div><div>@(item.Evento?.NombreEvento ?? "—")</div></div>
                    <div class="kv"><div class="k">Clasificación</div><div>@clasificacion</div></div>
                    <div class="kv"><div class="k">Tutor asignado</div><div>@nombreTutor</div></div>
                    <div class="kv"><div class="k">Líder</div><div>@nombreLider</div></div>
                    @if (integrantes.Any())
                    {
                        <div class="kv"><div class="k">Integrantes</div><div>@string.Join(", ", integrantes)</div></div>
                    }
                    <div class="kv"><div class="k">Descripción</div><div>@(item.DescripcionProyecto ?? "—")</div></div>
                </div>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="card card-ferias">
                <div class="card-body text-center py-4 text-secondary">
                    No tenés inscripciones registradas. Creá una nueva para participar.
                </div>
            </div>
        }
    }

    <div class="mt-4">
        @await Html.PartialAsync("_Pagination", Model, new ViewDataDictionary(ViewData) { { "PaginationAction", "Index" } })
    </div>

</div>