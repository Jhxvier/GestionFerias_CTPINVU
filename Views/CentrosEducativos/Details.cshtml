@model GestionFerias_CTPINVU.Models.CentrosEducativo

@{
    ViewData["Title"] = "Detalle del centro educativo";
}

<style>
    :root {
        --rojo: #BF1D1A;
        --amarillo: #F2B705;
        --naranja: #CB6021;
        --line: #e5e5e5;
        --muted: #666;
    }

    .page-wrap { max-width: 800px; margin: 40px auto; padding: 0 12px; }

    .card-detail {
        border-radius: 24px; border: 1px solid rgba(0,0,0,.06);
        box-shadow: 0 6px 20px rgba(0,0,0,.06); overflow: hidden;
    }

    .card-detail-top {
        background: linear-gradient(90deg, var(--rojo), var(--naranja));
        color: #fff; padding: 18px 22px;
        display: flex; align-items: center; gap: 10px;
    }

    .card-detail-body { padding: 24px; background: #fff; }

    .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0; }

    .info-row {
        display: flex; flex-direction: column;
        border-bottom: 1px solid var(--line); padding: 12px 0;
    }

    .info-row.full { grid-column: 1 / -1; }

    .info-label {
        font-size: 12px; color: var(--muted); margin-bottom: 4px;
        text-transform: uppercase; letter-spacing: .5px;
    }

    .info-value { font-size: 15px; color: #222; }

    .actions { margin-top: 20px; display: flex; justify-content: flex-end; gap: 12px; }

    .btnx {
        padding: 10px 20px; border-radius: 16px; border: 1px solid rgba(0,0,0,.22);
        font-size: 14px; cursor: pointer; text-decoration: none;
        display: inline-flex; align-items: center; gap: 8px;
    }

    .btnx.back { background: #fff; color: #111; }
    .btnx.edit { background: var(--amarillo); color: #111; border-color: transparent; }

    @@media (max-width: 600px) {
        .detail-grid { grid-template-columns: 1fr; }
    }
</style>

<div class="page-wrap">
    <div class="card-detail">
        <div class="card-detail-top">
            <i class="bi bi-building fs-5"></i>
            <span class="fw-semibold">Detalle del centro educativo</span>
        </div>

        <div class="card-detail-body">
            <div class="detail-grid">
                <div class="info-row full">
                    <div class="info-label">Nombre del centro</div>
                    <div class="info-value">@Model.NombreCentro</div>
                </div>

                <div class="info-row">
                    <div class="info-label">Director</div>
                    <div class="info-value">@(Model.NombreDirector ?? "—")</div>
                </div>

                <div class="info-row">
                    <div class="info-label">Circuito educativo</div>
                    <div class="info-value">@(Model.CircuitoEducativo ?? "—")</div>
                </div>

                <div class="info-row">
                    <div class="info-label">Dirección regional</div>
                    <div class="info-value">@(Model.DireccionRegional ?? "—")</div>
                </div>

                <div class="info-row">
                    <div class="info-label">Dirección</div>
                    <div class="info-value">@(Model.Direccion ?? "—")</div>
                </div>
            </div>

            <div class="actions">
                <a class="btnx back" asp-action="Index">
                    <i class="bi bi-arrow-left"></i> Volver
                </a>
                <a class="btnx edit" asp-action="Edit" asp-route-id="@Model.CentroId">
                    <i class="bi bi-pencil"></i> Editar
                </a>
            </div>
        </div>
    </div>
</div>
