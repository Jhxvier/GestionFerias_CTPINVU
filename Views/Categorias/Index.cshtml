@model GestionFerias_CTPINVU.Models.PaginatedList<GestionFerias_CTPINVU.Models.Categoria>

@{
    ViewData["Title"] = "Categorías";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<style>
    :root {
        --rojo: #BF1D1A;
        --verde: #6A9A2C;
        --amarillo: #F2B705;
        --naranja: #CB6021;
        --line: #e5e5e5;
        --muted: #666;
    }

    .header-ferias {
        background: linear-gradient(90deg,var(--rojo),var(--naranja));
        border-radius: 18px;
        color: #fff;
        padding: 18px 22px;
        box-shadow: 0 10px 30px rgba(0,0,0,.08);
    }

    .btn-verde { background: var(--verde); color: #fff; border: none; }
    .btn-naranja { background: var(--naranja); color: #fff; border: none; }
    .btn-amarillo { background: var(--amarillo); color: #111; border: none; }
    .btn-rojo { background: var(--rojo); color: #fff; border: none; }

    .card-ferias {
        border-radius: 20px;
        border: 1px solid rgba(0,0,0,.06);
        box-shadow: 0 6px 20px rgba(0,0,0,.06);
    }

    .badge-tipo {
        border-radius: 999px;
        padding: 4px 12px;
        font-size: 12px;
        font-weight: 600;
        border: 1px solid rgba(0,0,0,.08);
    }

    .tipo-artes { background: rgba(242,183,5,.18); color: #7a5d00; }
    .tipo-cientifica { background: rgba(106,154,44,.18); color: #2e4f13; }
</style>

<div class="container-xxl py-4">

    <div class="header-ferias mb-4">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
            <div>
                <h3 class="mb-1">Categorías</h3>
                <div class="opacity-75 small">Administrar categorías de ferias</div>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a asp-action="Create" class="btn btn-verde rounded-pill px-4">
                    <i class="bi bi-plus-circle me-1"></i> Crear nueva
                </a>
            </div>
        </div>
    </div>

    <div class="card card-ferias">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Tipo de feria</th>
                            <th class="text-center">Subcategorías</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cat in Model)
                        {
                            var tipoClase = (cat.TipoFeria ?? "").Contains("Artes") ? "tipo-artes" : "tipo-cientifica";

                            <tr>
                                <td class="fw-semibold">@cat.Nombre</td>
                                <td>
                                    <span class="badge-tipo @tipoClase">@cat.TipoFeria</span>
                                </td>
                                <td class="text-center">@cat.Subcategoria.Count</td>
                                <td class="text-end">
                                    <div class="d-inline-flex gap-2">
                                        <a asp-action="Edit" asp-route-id="@cat.CategoriaId"
                                           class="btn btn-sm btn-amarillo rounded-pill px-3">Editar</a>
                                        <a asp-action="Delete" asp-route-id="@cat.CategoriaId"
                                           class="btn btn-sm btn-rojo rounded-pill px-3">Eliminar</a>
                                        <a asp-action="Details" asp-route-id="@cat.CategoriaId"
                                           class="btn btn-sm btn-outline-secondary rounded-pill px-3">Detalles</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="mt-3">
                @await Html.PartialAsync("_Pagination", Model, new ViewDataDictionary(ViewData) { { "PaginationAction", "Index" } })
            </div>
        </div>
    </div>

</div>
