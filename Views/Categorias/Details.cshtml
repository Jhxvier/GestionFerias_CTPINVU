@model GestionFerias_CTPINVU.Models.Categoria

@{
    ViewData["Title"] = "Detalle de categoría";
}

<style>
    :root { --rojo: #BF1D1A; --amarillo: #F2B705; --naranja: #CB6021; --verde: #6A9A2C; --line: #e5e5e5; --muted: #666; }
    .page-wrap { max-width: 800px; margin: 40px auto; padding: 0 12px; }
    .card-detail { border-radius: 24px; border: 1px solid rgba(0,0,0,.06); box-shadow: 0 6px 20px rgba(0,0,0,.06); overflow: hidden; }
    .card-detail-top { background: linear-gradient(90deg, var(--rojo), var(--naranja)); color: #fff; padding: 18px 22px; display: flex; align-items: center; gap: 10px; }
    .card-detail-body { padding: 24px; background: #fff; }
    .info-row { display: flex; flex-direction: column; border-bottom: 1px solid var(--line); padding: 12px 0; }
    .info-label { font-size: 12px; color: var(--muted); margin-bottom: 4px; text-transform: uppercase; letter-spacing: .5px; }
    .info-value { font-size: 15px; color: #222; }
    .sub-list { margin-top: 16px; }
    .sub-item { padding: 8px 14px; border: 1px solid var(--line); border-radius: 12px; margin-bottom: 6px; font-size: 14px; display: flex; justify-content: space-between; align-items: center; }
    .actions { margin-top: 20px; display: flex; justify-content: flex-end; gap: 12px; }
    .btnx { padding: 10px 20px; border-radius: 16px; border: 1px solid rgba(0,0,0,.22); font-size: 14px; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; }
    .btnx.back { background: #fff; color: #111; }
    .btnx.edit { background: var(--amarillo); color: #111; border-color: transparent; }
</style>

<div class="page-wrap">
    <div class="card-detail">
        <div class="card-detail-top">
            <i class="bi bi-tags fs-5"></i>
            <span class="fw-semibold">Detalle de categoría</span>
        </div>

        <div class="card-detail-body">
            <div class="info-row">
                <div class="info-label">Nombre</div>
                <div class="info-value">@Model.Nombre</div>
            </div>

            <div class="info-row">
                <div class="info-label">Tipo de feria</div>
                <div class="info-value">@Model.TipoFeria</div>
            </div>

            <div class="info-row">
                <div class="info-label">Subcategorías (@Model.Subcategoria.Count)</div>
                <div class="sub-list">
                    @if (Model.Subcategoria.Any())
                    {
                        @foreach (var sub in Model.Subcategoria)
                        {
                            <div class="sub-item">
                                <span>@sub.Nombre</span>
                                <a asp-controller="Subcategorias" asp-action="Edit" asp-route-id="@sub.SubcategoriaId"
                                   class="btn btn-sm btn-outline-secondary rounded-pill px-3" style="font-size:12px;">Editar</a>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-muted small">Sin subcategorías registradas.</div>
                    }
                </div>
            </div>

            <div class="actions">
                <a class="btnx back" asp-action="Index">
                    <i class="bi bi-arrow-left"></i> Volver
                </a>
                <a class="btnx edit" asp-action="Edit" asp-route-id="@Model.CategoriaId">
                    <i class="bi bi-pencil"></i> Editar
                </a>
            </div>
        </div>
    </div>
</div>
