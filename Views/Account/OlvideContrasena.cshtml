@{
    ViewData["Title"] = "Olvidé mi contraseña";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Sistema de Ferias</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        :root {
            --rojo: #BF1D1A;
            --verde: #6A9A2C;
            --amarillo: #F2B705;
            --naranja: #CB6021;
            --bg: #f4f4f4;
            --card: #ffffff;
            --line: #e5e5e5;
            --muted: #666;
        }

        body {
            background: var(--bg);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .frame {
            width: 1100px;
            max-width: 95vw;
            background: #fff;
            border-radius: 22px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,.08);
        }

        .topbar {
            background: linear-gradient(90deg, var(--rojo), var(--naranja));
            color: #fff;
        }

        .logo {
            height: 40px;
            display: flex;
            align-items: center;
        }

        .pill {
            padding: .45rem .75rem;
            border-radius: 999px;
            background: rgba(255,255,255,.15);
            border: 1px solid rgba(255,255,255,.35);
            font-size: .85rem;
            white-space: nowrap;
        }

        .content {
            background: #fafafa;
            padding: 44px 18px;
        }

        .card-recuperar {
            width: 430px;
            max-width: 94vw;
            border-radius: 24px;
            border: 1px solid var(--line);
            box-shadow: 0 6px 20px rgba(0,0,0,.06);
            overflow: hidden;
        }

        .card-top {
            background: var(--verde);
            color: #fff;
        }

        .info {
            border: 2px dashed var(--amarillo);
            background: #fffbe6;
            color: #7a5d00;
            border-radius: 18px;
        }

        .form-control, .btn {
            border-radius: 16px;
        }

        .btn-send {
            background: var(--rojo);
            color: #fff;
            border: 1px solid rgba(0,0,0,.25);
        }

            .btn-send:hover {
                filter: brightness(.95);
                color: #fff;
            }

        .btn-back {
            background: #fff;
            color: #111;
            border: 1px solid rgba(0,0,0,.18);
        }

        a.link-rojo {
            color: var(--rojo);
            text-decoration: none;
        }

            a.link-rojo:hover {
                text-decoration: underline;
            }

        .muted {
            color: var(--muted);
        }
    </style>
</head>

<body>
    <div class="frame">

        <div class="topbar p-3 p-md-4">
            <div class="d-flex flex-column flex-md-row align-items-start align-items-md-center justify-content-between gap-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="logo">
                        <img src="~/images/logo-invu.png"
                             alt="Logo CTP INVU"
                             style="max-height:100%; width:auto;" />
                    </div>
                    <div class="lh-sm">
                        <div class="fw-bold">Sistema de Ferias</div>
                        <div class="small opacity-75">CTP INVU Las Cañas</div>
                    </div>
                </div>
                <div class="pill"><i class="bi bi-envelope-lock me-1"></i> Recuperación</div>
            </div>
        </div>

        <div class="content d-flex justify-content-center">
            <div class="card card-recuperar">

                <div class="card-top px-3 py-3">
                    <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-shield-lock fs-5"></i>
                            <span class="fw-semibold">Olvidé mi contraseña</span>
                        </div>
                        <span class="small opacity-75">Contraseña temporal</span>
                    </div>
                </div>

                <div class="p-3 p-md-4">

                    <div class="info p-3 mb-3">
                        Digite su <strong>correo</strong>. Se enviará una <strong>contraseña temporal</strong>
                        para que pueda ingresar y cambiarla.
                        <div class="small mt-2 muted">
                            Revise también <strong>Spam/No deseado</strong> si no le llega.
                        </div>
                    </div>

                    <form method="post" asp-action="OlvideContrasena" class="needs-validation" novalidate>
                        <div class="mb-3">
                            <label class="form-label small muted">Correo institucional</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white"><i class="bi bi-envelope"></i></span>
                                <input name="correo" type="email" class="form-control" placeholder="usuario@colegio.edu" required />
                                <div class="invalid-feedback">Digite un correo válido.</div>
                            </div>
                        </div>

                        <div class="d-flex gap-2 flex-wrap mt-3">
                            <button type="submit" class="btn btn-send flex-fill">
                                <i class="bi bi-send me-1"></i> Enviar contraseña temporal
                            </button>

                            <a class="btn btn-back flex-fill"
                               asp-controller="Account" asp-action="Login">
                                <i class="bi bi-arrow-left me-1"></i> Volver
                            </a>
                        </div>

                        <div class="text-center mt-3">
                            <a class="link-rojo small" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right me-1"></i> Volver a iniciar sesión
                            </a>
                        </div>

                        <div class="text-center mt-3 small muted">
                            © Sistema de Ferias
                        </div>
                    </form>

                </div>
            </div>
        </div>

    </div>

    <!-- Modal -->
    @if (TempData["MensajeRecuperacion"] != null)
    {
        <div class="modal fade" id="recoveryModal" tabindex="-1" aria-labelledby="recoveryModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content" style="border-radius: 20px; border: 0; box-shadow: 0 10px 30px rgba(0,0,0,.15); overflow: hidden;">
                    <div class="modal-header" style="background: var(--rojo); color: white; border-bottom: 0;">
                        <h5 class="modal-title" id="recoveryModalLabel"><i class="bi bi-info-circle me-2"></i>Recuperación</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body p-4 text-center">
                        <i class="bi bi-envelope-check text-success mb-3" style="font-size: 3rem;"></i>
                        <p class="fs-5 mb-0">@TempData["MensajeRecuperacion"]</p>
                    </div>
                    <div class="modal-footer justify-content-center" style="border-top: 0;">
                        <a asp-controller="Account" asp-action="Login" class="btn btn-primary px-4" style="border-radius: 999px;">Ir al Login</a>
                        <button type="button" class="btn btn-outline-secondary px-4" style="border-radius: 999px;" data-bs-dismiss="modal">Cerrar</button>
                    </div>
                </div>
            </div>
        </div>
    }

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (() => {
            const forms = document.querySelectorAll('.needs-validation');
            Array.from(forms).forEach(form => {
                form.addEventListener('submit', event => {
                    if (!form.checkValidity()) {
                        event.preventDefault();
                        event.stopPropagation();
                    }
                    form.classList.add('was-validated');
                }, false);
            });

            @if (TempData["MensajeRecuperacion"] != null)
            {
                <text>
                document.addEventListener('DOMContentLoaded', function() {
                    var myModal = new bootstrap.Modal(document.getElementById('recoveryModal'));
                    myModal.show();
                });
                </text>
            }
        })();
    </script>
</body>
</html>