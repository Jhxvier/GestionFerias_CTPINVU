@{
    ViewData["Title"] = "Registro";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Sistema de Ferias</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        :root {
            --rojo: #BF1D1A;
            --verde: #6A9A2C;
            --amarillo: #F2B705;
            --naranja: #CB6021;
            --bg: #f4f4f4;
            --card: #ffffff;
            --line: #e5e5e5;
            --muted: #666;
        }

        body {
            background: var(--bg);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .frame {
            width: 1100px;
            max-width: 95vw;
            background: #fff;
            border-radius: 22px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,.08);
            margin: 20px 0;
        }

        .topbar {
            background: linear-gradient(90deg, var(--rojo), var(--naranja));
            color: #fff;
        }

        .logo {
            height: 40px;
            display: flex;
            align-items: center;
        }

        .pill {
            padding: .45rem .75rem;
            border-radius: 999px;
            background: rgba(255,255,255,.15);
            border: 1px solid rgba(255,255,255,.35);
            font-size: .85rem;
            white-space: nowrap;
        }

        .content {
            background: #fafafa;
            padding: 44px 18px;
        }

        .card-login {
            width: 480px;
            max-width: 94vw;
            border-radius: 24px;
            border: 1px solid var(--line);
            box-shadow: 0 6px 20px rgba(0,0,0,.06);
            overflow: hidden;
        }

        .card-top {
            background: var(--naranja);
            color: #fff;
        }

        .form-control, .btn {
            border-radius: 16px;
        }

        .btn-login {
            background: var(--rojo);
            color: #fff;
            border: 1px solid rgba(0,0,0,.25);
        }

            .btn-login:hover {
                filter: brightness(.95);
                color: #fff;
            }

        .btn-alt {
            background: var(--verde);
            color: #fff;
            border: 1px solid rgba(0,0,0,.25);
        }

            .btn-alt:hover {
                filter: brightness(.95);
                color: #fff;
            }

        a.link-rojo {
            color: var(--rojo);
            text-decoration: none;
        }

            a.link-rojo:hover {
                text-decoration: underline;
            }

        .muted {
            color: var(--muted);
        }
    </style>
</head>

<body>
    <div class="frame">
        <!-- Topbar -->
        <div class="topbar p-3 p-md-4">
            <div class="d-flex flex-column flex-md-row align-items-start align-items-md-center justify-content-between gap-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="logo">
                        <img src="~/images/logo-invu.png"
                             alt="Logo CTP INVU"
                             style="max-height:100%; width:auto;" />
                    </div>
                    <div class="lh-sm">
                        <div class="fw-bold">Sistema de Ferias</div>
                        <div class="small opacity-75">CTP INVU Las Cañas</div>
                    </div>
                </div>
                <div class="pill"><i class="bi bi-person-plus me-1"></i> Registro de Usuario</div>
            </div>
        </div>

        <!-- Content -->
        <div class="content d-flex justify-content-center">
            <div class="card card-login">
                <div class="card-top px-3 py-3">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-person-plus-fill fs-5"></i>
                        <span class="fw-semibold">Crea una nueva cuenta</span>
                    </div>
                </div>

                <div class="p-3 p-md-4">
                    @if (TempData["ErrorRegistro"] != null)
                    {
                        <div class="alert alert-danger mb-3">
                            <i class="bi bi-exclamation-triangle me-1"></i>
                            @TempData["ErrorRegistro"]
                        </div>
                    }

                    <!-- Form (POST) -->
                    <form asp-controller="Account" asp-action="Registro" method="post" class="needs-validation" novalidate>
                        
                        <div class="mb-3">
                            <label class="form-label small muted">Número de documento o cédula *</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white"><i class="bi bi-card-text"></i></span>
                                <input name="documento" type="text" class="form-control" placeholder="Ej. 102340567" required />
                                <div class="invalid-feedback">Digite su documento de identidad.</div>
                            </div>
                        </div>

                        <div class="row g-2 mb-3">
                            <div class="col-md-6">
                                <label class="form-label small muted">Nombre(s) *</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white"><i class="bi bi-person"></i></span>
                                    <input name="nombres" type="text" class="form-control" placeholder="Juan" required />
                                    <div class="invalid-feedback">Obligatorio.</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small muted">Apellidos *</label>
                                <input name="apellidos" type="text" class="form-control" placeholder="Pérez López" required />
                                <div class="invalid-feedback">Obligatorio.</div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small muted">Correo Electrónico *</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white"><i class="bi bi-envelope"></i></span>
                                <input name="correo" type="email" class="form-control" placeholder="usuario@colegio.edu" required />
                                <div class="invalid-feedback">Digite un correo válido.</div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small muted">Contraseña *</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white"><i class="bi bi-key"></i></span>
                                <input name="clave" type="password" class="form-control" placeholder="••••••••" required />
                                <div class="invalid-feedback">Digite una contraseña para su cuenta.</div>
                            </div>
                            <div class="form-text small">La contraseña será encriptada de forma segura.</div>
                        </div>

                        <div class="d-flex gap-2 flex-wrap mt-4">
                            <button type="submit" class="btn btn-login flex-fill">
                                <i class="bi bi-check-circle me-1"></i> Completar Registro
                            </button>
                        </div>

                        <hr class="my-4 text-muted" />

                        <div class="text-center small">
                            ¿Ya tienes una cuenta? 
                            <a class="link-rojo fw-bold" asp-controller="Account" asp-action="Login">
                                Inicia sesión aquí
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (() => {
            const forms = document.querySelectorAll('.needs-validation');
            Array.from(forms).forEach(form => {
                form.addEventListener('submit', event => {
                    if (!form.checkValidity()) {
                        event.preventDefault();
                        event.stopPropagation();
                    }
                    form.classList.add('was-validated');
                }, false);
            });
        })();
    </script>
</body>
</html>
