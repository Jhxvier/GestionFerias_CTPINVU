@model GestionFerias_CTPINVU.Models.Subcategoria

@{
    ViewData["Title"] = "Eliminar subcategoría";
}

<style>
    :root { --rojo: #BF1D1A; --line: #e5e5e5; --muted: #666; }
    .page-wrap { max-width: 700px; margin: 40px auto; padding: 0 12px; }
    .card-delete { border-radius: 24px; border: 1px solid rgba(0,0,0,.06); box-shadow: 0 6px 20px rgba(0,0,0,.06); overflow: hidden; }
    .card-delete-top { background: var(--rojo); color: #fff; padding: 18px 22px; display: flex; align-items: center; gap: 10px; }
    .card-delete-body { padding: 24px; background: #fff; }
    .info-row { display: flex; border-bottom: 1px solid var(--line); padding: 10px 0; }
    .info-row:last-child { border-bottom: none; }
    .info-label { width: 160px; font-size: 13px; color: var(--muted); flex-shrink: 0; }
    .info-value { font-size: 14px; color: #222; }
    .actions { margin-top: 20px; display: flex; justify-content: flex-end; gap: 12px; }
    .btnx { padding: 10px 20px; border-radius: 16px; border: 1px solid rgba(0,0,0,.22); font-size: 14px; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; }
    .btnx.cancel { background: #fff; color: #111; }
    .btnx.delete { background: var(--rojo); color: #fff; border-color: transparent; }
</style>

<div class="page-wrap">
    <div class="card-delete">
        <div class="card-delete-top">
            <i class="bi bi-exclamation-triangle-fill fs-5"></i>
            <span class="fw-semibold">Confirmar eliminación</span>
        </div>

        <div class="card-delete-body">
            <p class="mb-3">¿Está seguro de que desea eliminar la siguiente subcategoría?</p>

            <div class="info-row">
                <div class="info-label">Nombre</div>
                <div class="info-value">@Model.Nombre</div>
            </div>

            <div class="info-row">
                <div class="info-label">Categoría</div>
                <div class="info-value">@Model.Categoria?.Nombre</div>
            </div>

            <div class="info-row">
                <div class="info-label">Tipo de feria</div>
                <div class="info-value">@Model.Categoria?.TipoFeria</div>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="SubcategoriaId" />
                <div class="actions">
                    <a class="btnx cancel" asp-action="Index">Cancelar</a>
                    <button class="btnx delete" type="submit">
                        <i class="bi bi-trash"></i> Eliminar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
