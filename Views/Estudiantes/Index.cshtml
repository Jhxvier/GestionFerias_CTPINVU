@model IEnumerable<GestionFerias_CTPINVU.Models.Estudiante>

@{
    ViewData["Title"] = "Estudiantes";
}

<style>
    :root {
        --rojo: #BF1D1A;
        --verde: #6A9A2C;
        --amarillo: #F2B705;
        --naranja: #CB6021;
        --bg: #f4f4f4;
        --card: #ffffff;
        --line: #e5e5e5;
        --muted: #666;
    }
    .marco-ui {
        background: #fff;
        border-radius: 22px;
        box-shadow: 0 10px 30px rgba(0,0,0,.08);
        overflow: hidden;
    }

    .contenido-ui {
        padding: 28px;
        background: #fafafa;
        min-height: 520px;
        border-radius: 22px;
    }

    .tarjeta-ui {
        background: var(--card);
        border-radius: 24px;
        box-shadow: 0 6px 20px rgba(0,0,0,.06);
        overflow: hidden;
        border: 0;
    }

    .zona-filtros {
        border-bottom: 1px solid var(--line);
    }

    .form-control, .form-select {
        border-radius: 16px;
    }

    .btn-crear {
        background: var(--verde);
        border-color: #000;
        border-radius: 16px;
        color: #fff;
    }

    .btn-filtrar {
        background: var(--naranja);
        border-color: #000;
        border-radius: 16px;
        color: #fff;
    }
    .tabla-ui {
        border-collapse: separate;
        border-spacing: 0 10px;
    }

        .tabla-ui thead th {
            font-size: 13px;
            color: var(--muted);
            font-weight: 400;
            border: 0 !important;
            white-space: nowrap;
        }

        .tabla-ui tbody tr {
            background: #fff;
            box-shadow: 0 3px 10px rgba(0,0,0,.05);
        }

        .tabla-ui tbody td {
            font-size: 13px;
            border-top: 1px solid var(--line);
            border-bottom: 1px solid var(--line);
            vertical-align: middle;
        }

            .tabla-ui tbody td:first-child {
                border-left: 1px solid var(--line);
                border-top-left-radius: 16px;
                border-bottom-left-radius: 16px;
            }

            .tabla-ui tbody td:last-child {
                border-right: 1px solid var(--line);
                border-top-right-radius: 16px;
                border-bottom-right-radius: 16px;
            }

    .badge-estado {
        border-radius: 999px;
        padding: 6px 10px;
        font-weight: 700;
        font-size: 12px;
        border: 1px solid var(--line);
        background: #fafafa;
        display: inline-block;
        white-space: nowrap;
    }

    .btn-accion {
        border-radius: 14px;
        border: 1px solid #000;
        font-size: 13px;
        padding: 8px 12px;
        text-decoration: none;
        display: inline-block;
        white-space: nowrap;
    }

    .btn-editar {
        background: var(--amarillo);
        color: #111;
    }

    .btn-eliminar {
        background: var(--rojo);
        color: #fff;
    }
</style>

<div class="marco-ui">
    <div class="contenido-ui">

        <!-- Encabezado -->
        <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
            <div>
                <h2 class="mb-1">Lista de estudiantes</h2>
                <p class="mb-0 text-secondary">Gestión de estudiantes (solo Administrador).</p>
            </div>

            <a asp-action="Create" class="btn btn-crear">
                + Crear nuevo
            </a>
        </div>

        <!-- Card -->
        <div class="card tarjeta-ui mt-3">

            <!-- Filtros -->
            <div class="p-3 zona-filtros">
                <div class="row g-2 align-items-end">
                    <div class="col-12 col-md-6 col-lg-5">
                        <label class="form-label text-secondary mb-1">Buscar</label>
                        <input id="textoBuscar" type="text" class="form-control"
                               placeholder="Nombre, documento o correo..." />
                    </div>

                    <div class="col-12 col-md-4 col-lg-3">
                        <label class="form-label text-secondary mb-1">Grado</label>
                        <select id="filtroGrado" class="form-select">
                            <option value="">Todos</option>
                            <option value="7">7°</option>
                            <option value="8">8°</option>
                            <option value="9">9°</option>
                            <option value="10">10°</option>
                            <option value="11">11°</option>
                        </select>
                    </div>

                    <div class="col-12 col-md-4 col-lg-2">
                        <button type="button" class="btn btn-filtrar w-100">Filtrar</button>
                    </div>
                </div>
            </div>

            <!-- Tabla -->
            <div class="p-3">
                <div class="table-responsive">
                    <table class="table tabla-ui align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Documento</th>
                                <th>Nombre</th>
                                <th>Correo</th>
                                <th>Grado</th>
                                <th>Estado</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model)
                            {
                                var documento = item.Usuario?.Persona?.Documento ?? "—";
                                var nombres = item.Usuario?.Persona?.Nombres ?? "—";
                                var apellidos = item.Usuario?.Persona?.Apellidos ?? "—";
                                var correo = item.Usuario?.Correo ?? "—";
                                var grado = item.Grado?.ToString() ?? "—";
                                var estado = item.Usuario?.Estado?.ToString() ?? "—";

                                <tr>
                                    <td>@documento</td>
                                    <td>@($"{nombres} {apellidos}")</td>
                                    <td>@correo</td>
                                    <td>@grado</td>
                                    <td>
                                        @if (estado == "Activo")
                                        {
                                            <span class="badge-estado bg-success text-white">Activo</span>
                                        }
                                        else if (estado == "Inactivo")
                                        {
                                            <span class="badge-estado bg-secondary text-white">Inactivo</span>
                                        }
                                        else
                                        {
                                            <span class="badge-estado bg-light text-dark">—</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <div class="d-inline-flex gap-2 flex-wrap justify-content-end">
                                            <a asp-action="Edit" asp-route-id="@item.UsuarioId" class="btn-accion btn-editar">Editar</a>
                                            <a asp-action="Delete" asp-route-id="@item.UsuarioId" class="btn-accion btn-eliminar">Eliminar</a>
                                        </div>
                                    </td>
                                </tr>
                            }

                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-secondary">
                                        No hay estudiantes para mostrar.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</div>