@model GestionFerias_CTPINVU.Models.ResultadosEvento

@{
    ViewData["Title"] = "Eliminar Resultados";
    var juezNombre = Model.JuezResponsableUsuario?.Juez?.Persona != null ? $"{Model.JuezResponsableUsuario.Juez.Persona.Nombres} {Model.JuezResponsableUsuario.Juez.Persona.Apellidos}" : "—";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<style>
    :root { --rojo: #BF1D1A; --line: #e5e5e5; --muted: #666; }
    .page-wrap { max-width: 700px; margin: 40px auto; padding: 0 12px; }
    .card-delete { border-radius: 24px; border: 1px solid rgba(0,0,0,.06); box-shadow: 0 6px 20px rgba(0,0,0,.06); overflow: hidden; }
    .card-delete-top { background: var(--rojo); color: #fff; padding: 18px 22px; display: flex; align-items: center; gap: 10px; }
    .card-delete-body { padding: 24px; background: #fff; }
    .info-row { display: flex; border-bottom: 1px solid var(--line); padding: 10px 0; }
    .info-row:last-child { border-bottom: none; }
    .info-label { width: 160px; font-size: 13px; color: var(--muted); flex-shrink: 0; }
    .info-value { font-size: 14px; color: #222; }
    .actions { margin-top: 20px; display: flex; justify-content: flex-end; gap: 12px; }
    .btnx { padding: 10px 20px; border-radius: 16px; border: 1px solid rgba(0,0,0,.22); font-size: 14px; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; }
    .btnx.cancel { background: #fff; color: #111; }
    .btnx.delete { background: var(--rojo); color: #fff; border-color: transparent; }
</style>

<div class="page-wrap">
    <div class="card-delete">
        <div class="card-delete-top">
            <i class="bi bi-exclamation-triangle-fill fs-5"></i>
            <span class="fw-semibold">Confirmar eliminación de resultados</span>
        </div>

        <div class="card-delete-body">
            <p class="mb-3 text-danger fw-bold">¿Está seguro de que desea eliminar permanentemente los resultados de este evento? Esta acción no se puede deshacer.</p>

            <div class="info-row">
                <div class="info-label">ID de Registro</div>
                <div class="info-value">RES-@Model.ResultadoEventoId</div>
            </div>

            <div class="info-row">
                <div class="info-label">Evento</div>
                <div class="info-value">@(Model.Evento?.NombreEvento ?? "—")</div>
            </div>

            <div class="info-row">
                <div class="info-label">Juez Responsable</div>
                <div class="info-value">@juezNombre</div>
            </div>

            <div class="info-row">
                <div class="info-label">Fecha de Publicación</div>
                <div class="info-value">@(Model.FechaPublicacion?.ToString("dd/MM/yyyy HH:mm") ?? "—")</div>
            </div>

            <div class="info-row">
                <div class="info-label">Estado</div>
                <div class="info-value">@(Model.EstadoResultados ?? "Pendiente")</div>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="ResultadoEventoId" />
                <div class="actions">
                    <a class="btnx cancel" asp-action="Index">Cancelar</a>
                    <button class="btnx delete" type="submit">
                        <i class="bi bi-trash"></i> Eliminar Definitivamente
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
