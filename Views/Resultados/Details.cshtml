@model GestionFerias_CTPINVU.Models.ResultadosEvento

@{
    ViewData["Title"] = "Detalle de Resultados";
    var esAdminOCoord = (bool)(ViewData["EsAdminOCoord"] ?? false);
    
    var estado = Model.EstadoResultados ?? "Pendiente";
    var claseEstado = estado == "Publicado" ? "estado-publicado" : "estado-pendiente";

    var top1 = Model.ResultadosGanadores.FirstOrDefault(g => g.Posicion == 1);
    var top2 = Model.ResultadosGanadores.FirstOrDefault(g => g.Posicion == 2);
    var top3 = Model.ResultadosGanadores.FirstOrDefault(g => g.Posicion == 3);

    string RenderTop(GestionFerias_CTPINVU.Models.ResultadosGanadore? top)
    {
        if (top == null || top.Inscripcion == null) return "—";
        var lider = top.Inscripcion.LiderUsuario?.Persona != null ? $"{top.Inscripcion.LiderUsuario.Persona.Nombres} {top.Inscripcion.LiderUsuario.Persona.Apellidos}" : "—";
        return $"<div class='lugar-box'><strong>{top.Inscripcion.TituloProyecto}</strong> <br> <span class='text-muted' style='font-size:13px;'>{lider}</span></div>";
    }

    var juezNombre = Model.JuezResponsableUsuario?.Juez?.Persona != null ? $"{Model.JuezResponsableUsuario.Juez.Persona.Nombres} {Model.JuezResponsableUsuario.Juez.Persona.Apellidos}" : "—";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<style>
    :root { --rojo: #BF1D1A; --amarillo: #F2B705; --naranja: #CB6021; --verde: #6A9A2C; --line: #e5e5e5; --muted: #666; }
    .page-wrap { max-width: 800px; margin: 40px auto; padding: 0 12px; }
    .card-detail { border-radius: 24px; border: 1px solid rgba(0,0,0,.06); box-shadow: 0 6px 20px rgba(0,0,0,.06); overflow: hidden; }
    .card-detail-top { background: linear-gradient(90deg, var(--rojo), var(--naranja)); color: #fff; padding: 18px 22px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; }
    .card-detail-body { padding: 24px; background: #fff; }
    .info-row { display: flex; flex-direction: column; border-bottom: 1px solid var(--line); padding: 12px 0; }
    .info-row:last-child { border-bottom: none; }
    .info-label { font-size: 12px; color: var(--naranja); font-weight: bold; margin-bottom: 4px; text-transform: uppercase; letter-spacing: .5px; }
    .info-value { font-size: 15px; color: #222; }
    
    .podium-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-top: 10px; }
    .podium-box { border: 1px solid var(--line); border-radius: 12px; padding: 12px; text-align: center; background: #fafafa; }
    .podium-pos { font-size: 18px; font-weight: bold; margin-bottom: 6px; }
    .p1 { color: #d4af37; } /* Gold */
    .p2 { color: #c0c0c0; } /* Silver */
    .p3 { color: #cd7f32; } /* Bronze */
    .podium-nota { display: inline-block; margin-top: 8px; background: #fff; border: 1px solid var(--naranja); color: var(--naranja); padding: 2px 8px; border-radius: 6px; font-weight: bold; font-size: 13px; }

    .badge-estado { border-radius: 999px; padding: 5px 12px; font-weight: 600; font-size: 12px; border: 1px solid rgba(255,255,255,.35); }
    .estado-pendiente { background: #fff8d6; color: #7a5d00; }
    .estado-publicado { background: #eef8e6; color: var(--verde); }
    
    .actions { margin-top: 20px; display: flex; justify-content: flex-end; gap: 12px; }
    .btnx { padding: 10px 20px; border-radius: 16px; border: 1px solid rgba(0,0,0,.22); font-size: 14px; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; }
    .btnx.back { background: #fff; color: #111; }
    .btnx.edit { background: var(--amarillo); color: #111; border-color: transparent; }

    @@media(max-width: 600px) {
        .podium-grid { grid-template-columns: 1fr; }
    }
</style>

<div class="page-wrap">
    <div class="card-detail">
        <div class="card-detail-top">
            <div>
                <div class="fw-semibold fs-5">Resultados - @(Model.Evento?.NombreEvento ?? "—")</div>
                <div class="opacity-75 small">RES-@Model.ResultadoEventoId</div>
            </div>
            <span class="badge-estado @claseEstado">@estado</span>
        </div>

        <div class="card-detail-body">
            
            <div class="info-row">
                <div class="info-label">Evento Evaluado</div>
                <div class="info-value">@(Model.Evento?.NombreEvento ?? "—")</div>
            </div>

            <div class="info-row" style="border-bottom:none;">
                <div class="info-label">Ganadores Oficiales</div>
                <div class="podium-grid">
                    <div class="podium-box">
                        <div class="podium-pos p2"><i class="bi bi-award-fill"></i> 2do Lugar</div>
                        @Html.Raw(RenderTop(top2))
                        @if(top2 != null) { <div class="podium-nota">@top2.Nota pts</div> }
                    </div>
                    <div class="podium-box" style="transform: scale(1.05); border-color: #d4af37; background:#fffdf5; box-shadow: 0 4px 10px rgba(212, 175, 55, 0.2);">
                        <div class="podium-pos p1"><i class="bi bi-trophy-fill"></i> 1er Lugar</div>
                        @Html.Raw(RenderTop(top1))
                        @if(top1 != null) { <div class="podium-nota">@top1.Nota pts</div> }
                    </div>
                    <div class="podium-box">
                        <div class="podium-pos p3"><i class="bi bi-award-fill"></i> 3er Lugar</div>
                        @Html.Raw(RenderTop(top3))
                        @if(top3 != null) { <div class="podium-nota">@top3.Nota pts</div> }
                    </div>
                </div>
            </div>

            <div class="info-row" style="margin-top: 10px;">
                <div class="info-label">Juez / Responsable de la calificación</div>
                <div class="info-value">@juezNombre</div>
            </div>

            <div class="info-row">
                <div class="info-label">Fecha de Publicación</div>
                <div class="info-value">@(Model.FechaPublicacion?.ToString("dd/MM/yyyy HH:mm") ?? "—")</div>
            </div>

            <div class="info-row">
                <div class="info-label">Resolución Final / Comentarios</div>
                <div class="info-value" style="white-space: pre-wrap;">@(Model.ResolucionFinal ?? "Sin comentarios adicionales registrados.")</div>
            </div>

            <div class="actions">
                <a class="btnx back" asp-action="Index">
                    <i class="bi bi-arrow-left"></i> Volver a Resultados
                </a>
                @if (esAdminOCoord)
                {
                    <a class="btnx edit" asp-action="Edit" asp-route-id="@Model.ResultadoEventoId">
                        <i class="bi bi-pencil"></i> Modificar Resultados
                    </a>
                }
            </div>
        </div>
    </div>
</div>
