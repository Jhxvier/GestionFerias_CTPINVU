@model IEnumerable<GestionFerias_CTPINVU.Models.ResultadosEvento>

@{
    ViewData["Title"] = "Resultados";
    var esAdminOCoord = (bool)(ViewData["EsAdminOCoord"] ?? false);
}

<style>
    :root {
        --rojo: #BF1D1A;
        --verde: #6A9A2C;
        --amarillo: #F2B705;
        --naranja: #CB6021;
        --bg: #f4f4f4;
        --card: #ffffff;
        --line: #e5e5e5;
        --muted: #666;
        --text: #222;
    }

    .marco-ui {
        background: #fff;
        border-radius: 22px;
        box-shadow: 0 10px 30px rgba(0,0,0,.08);
        overflow: hidden;
    }

    .contenido-ui {
        padding: 28px;
        background: #fafafa;
        min-height: 520px;
        border-radius: 22px;
    }

    .tarjeta-ui {
        background: var(--card);
        border-radius: 24px;
        box-shadow: 0 6px 20px rgba(0,0,0,.06);
        overflow: hidden;
        border: 1px solid var(--line);
    }

    .zona-filtros {
        padding: 16px;
        border-bottom: 1px solid var(--line);
    }

    .form-control, .form-select {
        border-radius: 16px;
        height: 44px;
    }

    .btn-filtrar {
        background: var(--naranja);
        border-color: #000;
        border-radius: 16px;
        color: #fff;
        height: 44px;
    }

    .tabla-ui {
        border-collapse: separate;
        border-spacing: 0 10px;
    }

    .tabla-ui thead th {
        text-align: left;
        font-size: 13px;
        color: var(--muted);
        font-weight: 400;
        border: 0 !important;
        white-space: nowrap;
    }

    .tabla-ui tbody tr {
        background: #fff;
        box-shadow: 0 3px 10px rgba(0,0,0,.05);
    }

    .tabla-ui tbody td {
        padding: 12px;
        font-size: 13px;
        border-top: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
        vertical-align: middle;
    }

    .tabla-ui tbody td:first-child {
        border-left: 1px solid var(--line);
        border-top-left-radius: 16px;
        border-bottom-left-radius: 16px;
    }

    .tabla-ui tbody td:last-child {
        border-right: 1px solid var(--line);
        border-top-right-radius: 16px;
        border-bottom-right-radius: 16px;
    }

    .badge-estado {
        display: inline-block;
        padding: 6px 10px;
        border-radius: 999px;
        font-size: 12px;
        border: 1px solid var(--line);
        background: #fafafa;
        white-space: nowrap;
        font-weight: 700;
    }

    .estado-pendiente { background: #fff8d6; border-color: #f0d36b; color: #7a5d00; }
    .estado-publicado { background: #eef8e6; border-color: #cfe9b6; color: var(--verde); }

    .btn-accion {
        padding: 8px 12px;
        border-radius: 14px;
        border: 1px solid #000;
        background: #fff;
        font-size: 13px;
        text-decoration: none;
        display: inline-block;
        white-space: nowrap;
    }

    .btn-ver { background: var(--amarillo); color: #111; }
    .btn-gestionar { background: var(--verde); color: #fff; }
    .btn-eliminar { background: var(--rojo); color: #fff; border-color: transparent; }

    .nota-ui {
        margin-top: 10px;
        font-size: 12px;
        color: var(--muted);
    }
    
    .lugar-box {
        font-size: 12px;
    }
    .lugar-box .lider {
        color: var(--muted);
        font-size: 11px;
    }
    .lugar-box .nota {
        font-weight: bold;
        color: var(--naranja);
    }
</style>

<div class="marco-ui">
    <div class="contenido-ui">

        <!-- Encabezado -->
        <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
            <div>
                <h2 class="mb-1" style="color:var(--text);">Resultados</h2>
                <p class="mb-0 text-secondary">
                    Todos pueden consultar resultados. Solo Juez/Admin/Coordinador pueden registrar calificación.
                </p>
            </div>
            @if (esAdminOCoord)
            {
                <div class="d-flex gap-2 flex-wrap">
                    <a asp-action="Create" class="btn btn-filtrar d-inline-flex align-items-center gap-2 px-4 shadow-sm" style="background:var(--verde); font-weight:600; border-color:rgba(0,0,0,.2);">
                        <i class="bi bi-plus-circle"></i> Nuevo Resultado
                    </a>
                </div>
            }
        </div>

        <div class="tarjeta-ui mt-3">

            <!-- Filtros-->
            <form method="get" action="/Resultados/Index" class="zona-filtros">
                <div class="row g-2 align-items-end">

                    <div class="col-12 col-md-4 col-lg-3">
                        <label class="form-label text-secondary mb-1">Buscar</label>
                        <input name="textoBuscar" type="text" class="form-control"
                               placeholder="Nombre evento, resolución..." value="@ViewData["CurrentBuscar"]" />
                    </div>

                    <div class="col-12 col-md-4 col-lg-4">
                        <label class="form-label text-secondary mb-1">Evento</label>
                        <select name="filtroEvento" class="form-select" asp-items="ViewBag.EventosList">
                            <option value="">Seleccione evento</option>
                        </select>
                    </div>

                    <div class="col-12 col-md-4 col-lg-3">
                        <label class="form-label text-secondary mb-1">Estado</label>
                        <select name="filtroEstado" class="form-select">
                            <option value="" selected="@(ViewData["CurrentEstado"]?.ToString() == "" ? "selected" : null)">Todos</option>
                            <option value="Pendiente" selected="@(ViewData["CurrentEstado"]?.ToString() == "Pendiente" ? "selected" : null)">Pendiente</option>
                            <option value="Publicado" selected="@(ViewData["CurrentEstado"]?.ToString() == "Publicado" ? "selected" : null)">Publicado</option>
                        </select>
                    </div>

                    <div class="col-12 col-md-12 col-lg-2">
                        <button type="submit" class="btn btn-filtrar w-100">Filtrar</button>
                    </div>

                </div>
            </form>

            <!-- Tabla -->
            <div class="p-3">
                <div class="table-responsive">
                    <table class="table tabla-ui align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Evento</th>
                                <th>Estado</th>
                                <th>1er lugar</th>
                                <th>2do lugar</th>
                                <th>3er lugar</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model)
                            {
                                var evento = item.Evento?.NombreEvento ?? "—";
                                var estado = item.EstadoResultados?.ToString() ?? "Pendiente";
                                var claseEstado = (estado == "Publicado") ? "estado-publicado" : "estado-pendiente";

                                var top1 = item.ResultadosGanadores.FirstOrDefault(g => g.Posicion == 1);
                                var top2 = item.ResultadosGanadores.FirstOrDefault(g => g.Posicion == 2);
                                var top3 = item.ResultadosGanadores.FirstOrDefault(g => g.Posicion == 3);

                                string RenderTop(GestionFerias_CTPINVU.Models.ResultadosGanadore? top)
                                {
                                    if (top == null || top.Inscripcion == null) return "—";
                                    var lider = top.Inscripcion.LiderUsuario?.Persona != null ? $"{top.Inscripcion.LiderUsuario.Persona.Nombres} {top.Inscripcion.LiderUsuario.Persona.Apellidos}" : "—";
                                    return $"<div class='lugar-box'><strong>{top.Inscripcion.TituloProyecto}</strong><br><span class='lider'>{lider}</span><br><span class='nota'>Nota: {top.Nota}</span></div>";
                                }

                                <tr>
                                    <td>@evento</td>
                                    <td>
                                        <span class="badge-estado @claseEstado">@estado</span>
                                    </td>
                                    <td>@Html.Raw(RenderTop(top1))</td>
                                    <td>@Html.Raw(RenderTop(top2))</td>
                                    <td>@Html.Raw(RenderTop(top3))</td>

                                    <td class="text-end">
                                        <div class="d-inline-flex gap-2 flex-wrap justify-content-end">
                                            <a asp-action="Details" asp-route-id="@item.ResultadoEventoId" class="btn-accion btn-ver">
                                                Ver
                                            </a>
                                            @if (esAdminOCoord)
                                            {
                                                <a asp-action="Edit" asp-route-id="@item.ResultadoEventoId" class="btn-accion btn-gestionar">
                                                    Editar
                                                </a>
                                                <a asp-action="Delete" asp-route-id="@item.ResultadoEventoId" class="btn-accion btn-eliminar">
                                                    Eliminar
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }

                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-secondary">
                                        No hay resultados para mostrar.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="nota-ui">
                    * El botón “Editar” y “Eliminar” se muestra solo a Juez, Administrador y Coordinador.
                </div>
            </div>
        </div>
    </div>
</div>