@model GestionFerias_CTPINVU.Models.ResultadoEventoViewModel

@{
    ViewData["Title"] = "Calificar Evento";
    var juezNombre = ViewData["JuezNombre"] as string ?? "Juez Actual";
    var listaEventos = ViewData["EventoId"] as SelectList;
}

<style>
    :root { --rojo: #BF1D1A; --verde: #6A9A2C; --amarillo: #F2B705; --naranja: #CB6021; --line: #e5e5e5; --muted: #666; --bg: #fafafa; }
    .page-wrap { max-width: 1000px; margin: 22px auto; padding: 0 8px; }
    .content { padding: 26px; background: #fafafa; border-radius: 22px; box-shadow: 0 10px 30px rgba(0,0,0,.06); border: 1px solid rgba(0,0,0,.04); }
    .header h2 { margin: 0; font-weight: normal; color: #222; }
    .header p { margin: 6px 0 0; color: var(--muted); font-size: 14px; }
    .card-form { margin-top: 18px; background: #fff; border-radius: 24px; box-shadow: 0 6px 20px rgba(0,0,0,.06); overflow: hidden; border: 1px solid rgba(0,0,0,.04); }
    .card-top { background: var(--verde); color: #fff; padding: 16px 18px; display: flex; justify-content: space-between; align-items: center; gap: 10px; flex-wrap: wrap; }
    .tag { font-size: 12px; padding: 4px 10px; border: 1px solid rgba(255,255,255,.35); border-radius: 999px; background: rgba(255,255,255,.12); }
    .form { padding: 20px; background: #fff; }
    .section { margin-bottom: 18px; padding: 14px; border: 1px solid var(--line); border-radius: 18px; background: #fff; }
    .section-title { margin: 0 0 12px 0; font-weight: normal; font-size: 14px; color: var(--naranja); }
    .section-ganadores { border: 2px dashed var(--amarillo); background: #fffbe6; }
    .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .field label { display: block; font-size: 13px; color: var(--muted); margin-bottom: 6px; }
    .field input, .field select, .field textarea { width: 100%; padding: 11px 12px; border-radius: 16px; border: 1px solid var(--line); background: #fff; font-family: Arial,sans-serif; outline: none; }
    .field input, .field select { height: 44px; }
    .field textarea { min-height: 100px; resize: none; }
    .field input:disabled { background: #f3f3f3; color: #666; cursor: not-allowed; }
    .field input:focus, .field select:focus, .field textarea:focus { border-color: rgba(191,29,26,.55); box-shadow: 0 0 0 4px rgba(191,29,26,.10); }
    .text-danger { font-size: 12px; color: #b00020; margin-top: 6px; display: block; }
    .nota-ayuda { font-size: 12px; color: var(--muted); margin-top: 10px; }
    .actions { margin-top: 18px; display: flex; justify-content: flex-end; gap: 12px; flex-wrap: wrap; }
    .btnx { padding: 10px 16px; border-radius: 16px; border: 1px solid rgba(0,0,0,.22); font-size: 14px; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 8px; text-decoration: none; user-select: none; }
    .btnx.cancel { background: #fff; color: #111; }
    .btnx.save { background: var(--verde); color: #fff; border-color: transparent; font-weight: bold; }
    @@media (max-width: 900px) { .grid { grid-template-columns: 1fr; } }
</style>

<div class="page-wrap">
    <div class="content">
        <div class="header">
            <h2>Colocar calificaciones / resultados</h2>
            <p>Selecciona el evento, define los top 3 ganadores y publica la resolución.</p>
        </div>

        <div class="card-form">
            <div class="card-top">
                <span class="fw-semibold">Resultados del evento</span>
                <span class="tag">Modo: Crear</span>
            </div>

            <div class="form">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="section">
                        <h3 class="section-title">Evento</h3>
                        <div class="grid">
                            <div class="field">
                                <label>Evento a calificar</label>
                                <select asp-for="EventoId" asp-items="listaEventos" id="eventoSelect">
                                    <option value="">Seleccione un evento</option>
                                </select>
                                <span asp-validation-for="EventoId" class="text-danger"></span>
                            </div>
                            <div class="field">
                                <label>Juez / Responsable</label>
                                <input disabled value="@juezNombre" />
                            </div>
                        </div>
                    </div>

                    <div class="section section-ganadores">
                        <h3 class="section-title">Ganadores — 1er lugar obligatorio, 2do y 3er opcionales</h3>
                        <div class="grid">
                            <!-- 1er Lugar (OBLIGATORIO) -->
                            <div class="field">
                                <label>Proyecto 1er Lugar <span style="color:#b00020;">*</span></label>
                                <select asp-for="Inscripcion1erLugarId" class="proyecto-select">
                                    <option value="">Seleccione evento primero</option>
                                </select>
                                <span asp-validation-for="Inscripcion1erLugarId" class="text-danger"></span>
                            </div>
                            <div class="field">
                                <label>Nota 1er lugar (0 - 100) <span style="color:#b00020;">*</span></label>
                                <input asp-for="Nota1erLugar" type="number" min="0" max="100" step="0.01" />
                                <span asp-validation-for="Nota1erLugar" class="text-danger"></span>
                            </div>

                            <!-- 2do Lugar (OPCIONAL) -->
                            <div class="field">
                                <label>Proyecto 2do Lugar <span style="color:var(--muted);font-size:11px;">(Opcional)</span></label>
                                <select asp-for="Inscripcion2doLugarId" class="proyecto-select" id="select2do">
                                    <option value="">Seleccione evento primero</option>
                                </select>
                                <span asp-validation-for="Inscripcion2doLugarId" class="text-danger"></span>
                            </div>
                            <div class="field" id="nota2doWrap">
                                <label>Nota 2do lugar (0 - 100)</label>
                                <input asp-for="Nota2doLugar" type="number" min="0" max="100" step="0.01" id="nota2do" />
                                <span asp-validation-for="Nota2doLugar" class="text-danger"></span>
                            </div>

                            <!-- 3er Lugar (OPCIONAL) -->
                            <div class="field" id="lugar3doWrap">
                                <label>Proyecto 3er Lugar <span style="color:var(--muted);font-size:11px;">(Opcional)</span></label>
                                <select asp-for="Inscripcion3erLugarId" class="proyecto-select" id="select3er">
                                    <option value="">Seleccione evento primero</option>
                                </select>
                                <span asp-validation-for="Inscripcion3erLugarId" class="text-danger"></span>
                            </div>
                            <div class="field" id="nota3erWrap">
                                <label>Nota 3er lugar (0 - 100)</label>
                                <input asp-for="Nota3erLugar" type="number" min="0" max="100" step="0.01" id="nota3er" />
                                <span asp-validation-for="Nota3erLugar" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="nota-ayuda">
                            <strong>1er lugar obligatorio.</strong> El 2do y 3er lugar son opcionales — solo complete si aplica. No puede haber 3er lugar sin 2do lugar.
                        </div>
                    </div>

                    <div class="section">
                        <h3 class="section-title">Resolución final</h3>
                        <div class="field" style="grid-column: 1 / -1;">
                            <label>Comentarios adicionales o acta de resolución (Opcional)</label>
                            <textarea asp-for="ResolucionFinal"></textarea>
                        </div>
                    </div>

                    <div class="actions">
                        <a class="btnx cancel" asp-action="Index">Cancelar</a>
                        <button class="btnx save" type="submit">Publicar Resultados</button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        var eventSelect = document.getElementById('eventoSelect');
        var projectSelects = document.querySelectorAll('.proyecto-select');

        eventSelect.addEventListener('change', function() {
            var eventId = this.value;
            
            projectSelects.forEach(function(select) {
                select.innerHTML = '<option value="">Cargando...</option>';
            });

            if (!eventId) {
                projectSelects.forEach(function(select) {
                    select.innerHTML = '<option value="">Seleccione evento primero</option>';
                });
                return;
            }

            fetch('/Resultados/GetInscripcionesPorEvento?eventoId=' + eventId)
                .then(r => r.json())
                .then(data => {
                    var html = '<option value="">Seleccione proyecto ganador</option>';
                    if (data.length === 0) {
                        html = '<option value="">No hay proyectos aprobados para este evento</option>';
                    } else {
                        data.forEach(p => {
                            html += '<option value="' + p.id + '">' + p.titulo + ' (' + p.lider + ')</option>';
                        });
                    }
                    projectSelects.forEach(function(select) {
                        select.innerHTML = html;
                    });
                })
                .catch(err => {
                    projectSelects.forEach(function(select) {
                        select.innerHTML = '<option value="">Error obteniendo datos</option>';
                    });
                });
        });
    });
</script>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}