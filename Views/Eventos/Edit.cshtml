@model GestionFerias_CTPINVU.Models.Evento

@{
    ViewData["Title"] = "Editar evento";
    var listaCentros = ViewBag.CentroId as IEnumerable<SelectListItem>;
}

<style>
    :root {
        --rojo: #BF1D1A;
        --verde: #6A9A2C;
        --amarillo: #F2B705;
        --naranja: #CB6021;
        --bg: #f4f4f4;
        --card: #ffffff;
        --line: #e5e5e5;
        --text: #222;
        --muted: #666;
    }

    * {
        box-sizing: border-box;
    }

    .page-wrap {
        max-width: 1200px;
        margin: 22px auto;
        padding: 0 8px;
    }

    .content {
        padding: 26px;
        background: #fafafa;
        border-radius: 22px;
        box-shadow: 0 10px 30px rgba(0,0,0,.06);
        border: 1px solid rgba(0,0,0,.04);
        min-height: 520px;
    }

    .header h2 {
        margin: 0;
        font-weight: normal;
        color: var(--text);
    }

    .header p {
        margin: 6px 0 0;
        color: var(--muted);
        font-size: 14px;
    }

    .card {
        margin-top: 18px;
        background: var(--card);
        border-radius: 24px;
        box-shadow: 0 6px 20px rgba(0,0,0,.06);
        overflow: hidden;
        border: 1px solid rgba(0,0,0,.04);
    }

    .card-top {
        background: var(--amarillo);
        color: #111;
        padding: 16px 18px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .mode {
        background: rgba(0,0,0,.08);
        border: 1px solid rgba(0,0,0,.15);
        padding: 6px 10px;
        border-radius: 999px;
        font-size: 12px;
    }

    .form {
        padding: 20px;
        background: #fff;
    }

    .section {
        margin-bottom: 18px;
        padding: 14px;
        border: 1px solid var(--line);
        border-radius: 18px;
        background: #fff;
    }

    .section-title {
        margin: 0 0 12px 0;
        font-weight: normal;
        font-size: 14px;
        color: var(--naranja);
    }

    .grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
    }

    .field label {
        display: block;
        font-size: 13px;
        color: var(--muted);
        margin-bottom: 6px;
    }

    .field input, .field select, .field textarea {
        width: 100%;
        padding: 11px 12px;
        border-radius: 16px;
        border: 1px solid var(--line);
        background: #fff;
        font-family: Arial, sans-serif;
        outline: none;
    }

        .field input:focus, .field select:focus, .field textarea:focus {
            border-color: rgba(191,29,26,.55);
            box-shadow: 0 0 0 4px rgba(191,29,26,.10);
        }

    .field textarea {
        min-height: 90px;
        resize: none;
    }

    .text-danger {
        font-size: 12px;
        color: #b00020;
        margin-top: 6px;
        display: block;
    }

    .actions {
        margin-top: 18px;
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        flex-wrap: wrap;
    }

    .btnx {
        padding: 10px 16px;
        border-radius: 16px;
        border: 1px solid rgba(0,0,0,.22);
        font-size: 14px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        text-decoration: none;
        user-select: none;
    }

        .btnx.cancel {
            background: #fff;
            color: #111;
        }

        .btnx.save {
            background: var(--rojo);
            color: #fff;
            border-color: transparent;
        }

    @@media (max-width: 900px) {
        .content {
            padding: 18px;
        }

        .grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="page-wrap">
    <div class="content">
        <div class="header">
            <h2>Editar evento</h2>
            <p>Modifique la información del evento.</p>
        </div>

        <div class="card">
            <div class="card-top">
                <span>Formulario de evento</span>
                <span class="mode">Modo: Editar</span>
            </div>

            <div class="form">
                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="EventoId" />

                    <div class="section">
                        <h3 class="section-title">Datos del centro educativo</h3>
                        <div class="grid">
                            <div class="field" style="grid-column:1 / -1;">
                                <label>Centro educativo</label>
                                <select asp-for="CentroId" asp-items="listaCentros"></select>
                                <span asp-validation-for="CentroId" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="section">
                        <h3 class="section-title">Datos del evento</h3>
                        <div class="grid">
                            <div class="field">
                                <label>Código del evento</label>
                                <input asp-for="CodigoEvento" />
                                <span asp-validation-for="CodigoEvento" class="text-danger"></span>
                            </div>

                            <div class="field">
                                <label>Nombre del evento</label>
                                <input asp-for="NombreEvento" />
                                <span asp-validation-for="NombreEvento" class="text-danger"></span>
                            </div>

                            <div class="field">
                                <label>Tipo de feria</label>
                                <select asp-for="TipoFeria">
                                    <option value="">Seleccione</option>
                                    <option value="Artes">Artes</option>
                                    <option value="Científica">Científica</option>
                                </select>
                                <span asp-validation-for="TipoFeria" class="text-danger"></span>
                            </div>

                            <div class="field">
                                <label>Estado</label>
                                <select asp-for="EstadoEvento">
                                    <option value="">Seleccione</option>
                                    <option value="En proceso">En proceso</option>
                                    <option value="Finalizado">Finalizado</option>
                                    <option value="Cancelado">Cancelado</option>
                                </select>
                                <span asp-validation-for="EstadoEvento" class="text-danger"></span>
                            </div>

                            <div class="field">
                                <label>Fecha de inicio</label>
                                <input asp-for="FechaInicio" type="date" />
                                <span asp-validation-for="FechaInicio" class="text-danger"></span>
                            </div>

                            <div class="field">
                                <label>Fecha de finalización</label>
                                <input asp-for="FechaFin" type="date" />
                                <span asp-validation-for="FechaFin" class="text-danger"></span>
                            </div>

                            <div class="field" style="grid-column:1 / -1;">
                                <label>Descripción</label>
                                <textarea asp-for="Descripcion"></textarea>
                                <span asp-validation-for="Descripcion" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="actions">
                        <a class="btnx cancel" asp-action="Index">Cancelar</a>
                        <button class="btnx save" type="submit">Guardar cambios</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}