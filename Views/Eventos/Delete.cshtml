@model GestionFerias_CTPINVU.Models.Evento

@{
    ViewData["Title"] = "Desactivar evento";
    var tieneInscripciones = (bool)(ViewData["TieneInscripciones"] ?? false);
}

<style>
    :root {
        --rojo: #BF1D1A;
        --verde: #6A9A2C;
        --amarillo: #F2B705;
        --naranja: #CB6021;
        --line: #e5e5e5;
        --muted: #666;
    }

    .page-wrap {
        max-width: 700px;
        margin: 40px auto;
        padding: 0 12px;
    }

    .card-delete {
        border-radius: 24px;
        border: 1px solid rgba(0,0,0,.06);
        box-shadow: 0 6px 20px rgba(0,0,0,.06);
        overflow: hidden;
    }

    .card-delete-top {
        background: var(--rojo);
        color: #fff;
        padding: 18px 22px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .card-delete-body {
        padding: 24px;
        background: #fff;
    }

    .info-row {
        display: flex;
        border-bottom: 1px solid var(--line);
        padding: 10px 0;
    }

        .info-row:last-child {
            border-bottom: none;
        }

    .info-label {
        width: 160px;
        font-size: 13px;
        color: var(--muted);
        flex-shrink: 0;
    }

    .info-value {
        font-size: 14px;
        color: #222;
    }

    .actions {
        margin-top: 20px;
        display: flex;
        justify-content: flex-end;
        gap: 12px;
    }

    .btnx {
        padding: 10px 20px;
        border-radius: 16px;
        border: 1px solid rgba(0,0,0,.22);
        font-size: 14px;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .btnx.cancel {
            background: #fff;
            color: #111;
        }

        .btnx.delete {
            background: var(--rojo);
            color: #fff;
            border-color: transparent;
        }
</style>

<div class="page-wrap">
    <div class="card-delete">
        <div class="card-delete-top">
            <i class="bi bi-exclamation-triangle-fill fs-5"></i>
            <span class="fw-semibold">Confirmar eliminación</span>
        </div>

        <div class="card-delete-body">
            <p class="mb-3">¿Está seguro de que desea desactivar el siguiente evento? Esta acción no se puede deshacer.</p>

            <div class="info-row">
                <div class="info-label">Código</div>
                <div class="info-value">@Model.CodigoEvento</div>
            </div>

            <div class="info-row">
                <div class="info-label">Nombre</div>
                <div class="info-value">@Model.NombreEvento</div>
            </div>

            <div class="info-row">
                <div class="info-label">Tipo de feria</div>
                <div class="info-value">@Model.TipoFeria</div>
            </div>

            <div class="info-row">
                <div class="info-label">Centro educativo</div>
                <div class="info-value">@Model.Centro?.NombreCentro</div>
            </div>

            <div class="info-row">
                <div class="info-label">Fecha de inicio</div>
                <div class="info-value">@Model.FechaInicio.ToString("dd/MM/yyyy")</div>
            </div>

            <div class="info-row">
                <div class="info-label">Fecha de fin</div>
                <div class="info-value">@Model.FechaFin.ToString("dd/MM/yyyy")</div>
            </div>

            <div class="info-row">
                <div class="info-label">Estado</div>
                <div class="info-value">@Model.EstadoEvento</div>
            </div>

            @if (TempData["ErrorEliminar"] != null)
            {
                <div style="background:#fff0f0;border:1px solid #f5c6c6;border-radius:12px;padding:12px 16px;margin-bottom:16px;display:flex;align-items:flex-start;gap:10px;">
                    <i class="bi bi-exclamation-circle-fill" style="color:#b00020;font-size:18px;flex-shrink:0;margin-top:2px;"></i>
                    <span style="font-size:13px;color:#b00020;">@TempData["ErrorEliminar"]</span>
                </div>
            }

            @if (tieneInscripciones)
            {
                <div style="background:#fff8e1;border:1px solid #ffe082;border-radius:12px;padding:14px 16px;margin-bottom:16px;">
                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
                        <i class="bi bi-shield-exclamation" style="color:#e65100;font-size:18px;"></i>
                        <strong style="color:#e65100;font-size:14px;">No se puede desactivar este evento</strong>
                    </div>
                    <p style="margin:0;font-size:13px;color:#555;">Este evento tiene inscripciones registradas. Para poder desactivarlo, primero debe gestionar o desactivar todas las inscripciones asociadas.</p>
                </div>
            }

            <form asp-action="Delete">
                <input type="hidden" asp-for="EventoId" />
                <div class="actions">
                    <a class="btnx cancel" asp-action="Index">Cancelar</a>
                    @if (!tieneInscripciones)
                    {
                        <button class="btnx delete" type="submit">
                            <i class="bi bi-trash"></i> Desactivar
                        </button>
                    }
                    else
                    {
                        <button class="btnx delete" type="button" disabled style="opacity:0.45;cursor:not-allowed;">
                            <i class="bi bi-lock"></i> No disponible
                        </button>
                    }
                </div>
            </form>
        </div>
    </div>
</div>
