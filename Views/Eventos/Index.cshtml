@using System.Globalization
@model GestionFerias_CTPINVU.Models.PaginatedList<GestionFerias_CTPINVU.Models.Evento>

@{
    ViewData["Title"] = "Gestión de eventos";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<style>
    :root {
        --rojo: #BF1D1A;
        --verde: #6A9A2C;
        --amarillo: #F2B705;
        --naranja: #CB6021;
        --line: #e5e5e5;
        --muted: #666;
    }

    .header-ferias {
        background: linear-gradient(90deg,var(--rojo),var(--naranja));
        border-radius: 18px;
        color: #fff;
        padding: 18px 22px;
        box-shadow: 0 10px 30px rgba(0,0,0,.08);
    }

    .btn-verde {
        background: var(--verde);
        color: #fff;
        border: none;
    }

    .btn-naranja {
        background: var(--naranja);
        color: #fff;
        border: none;
    }

    .btn-amarillo {
        background: var(--amarillo);
        color: #111;
        border: none;
    }

    .btn-rojo {
        background: var(--rojo);
        color: #fff;
        border: none;
    }

    .card-ferias {
        border-radius: 20px;
        border: 1px solid rgba(0,0,0,.06);
        box-shadow: 0 6px 20px rgba(0,0,0,.06);
    }

    .form-control.redondo, .form-select.redondo {
        border-radius: 16px;
    }

    .badge-estado {
        border: 1px solid rgba(0,0,0,.08);
        font-weight: 600;
    }

    .estado-proceso {
        background: rgba(203,96,33,.18);
        color: #7a2e0b;
    }

    .estado-finalizado {
        background: rgba(106,154,44,.18);
        color: #2e4f13;
    }

    .estado-cancelado {
        background: rgba(191,29,26,.18);
        color: #7a0f0d;
    }
</style>

<div class="container-xxl py-4">

    <div class="header-ferias mb-4">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
            <div>
                <h3 class="mb-1">Gestión de eventos</h3>
                <div class="opacity-75 small">Crear y administrar ferias</div>
            </div>

            <div class="d-flex gap-2 flex-wrap">
                <a asp-action="Create" class="btn btn-verde rounded-pill px-4">
                    <i class="bi bi-plus-circle me-1"></i> Crear nuevo
                </a>

                <button class="btn btn-amarillo rounded-pill px-4">
                    <i class="bi bi-funnel me-1"></i> Filtrar
                </button>

                <button class="btn btn-outline-light rounded-pill px-4">
                    <i class="bi bi-arrow-counterclockwise me-1"></i> Limpiar
                </button>
            </div>
        </div>
    </div>

    <div class="card card-ferias">
        <div class="card-body">

            <!-- FILTROS -->
            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <input class="form-control redondo" placeholder="Buscar evento..." />
                </div>
                <div class="col-md-3">
                    <select class="form-select redondo">
                        <option>Todos</option>
                        <option>En proceso</option>
                        <option>Finalizado</option>
                        <option>Cancelado</option>
                    </select>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Código</th>
                            <th>Evento</th>
                            <th>Tipo</th>
                            <th>Inicio</th>
                            <th>Final</th>
                            <th class="text-center">Estado</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var evento in Model)
                        {
                            var estado = (evento.EstadoEvento ?? "").Trim();

                            var claseEstado = estado switch
                            {
                                "En proceso" => "estado-proceso",
                                "Finalizado" => "estado-finalizado",
                                "Cancelado" => "estado-cancelado",
                                _ => ""
                            };

                            <tr>
                                <td>@evento.CodigoEvento</td>
                                <td>@evento.NombreEvento</td>
                                <td>@evento.TipoFeria</td>
                                <td>@evento.FechaInicio.ToString("dd/MM/yyyy", CultureInfo.InvariantCulture)</td>
                                <td>@evento.FechaFin.ToString("dd/MM/yyyy", CultureInfo.InvariantCulture)</td>

                                <td class="text-center">
                                    <span class="badge rounded-pill badge-estado @claseEstado px-3 py-2">
                                        @estado
                                    </span>
                                </td>

                                <td class="text-end">
                                    <div class="d-inline-flex gap-2">
                                        <a asp-action="Edit" asp-route-id="@evento.EventoId"
                                           class="btn btn-sm btn-amarillo rounded-pill px-3">
                                            Editar
                                        </a>

                                        <a asp-action="Delete" asp-route-id="@evento.EventoId"
                                           class="btn btn-sm btn-rojo rounded-pill px-3">
                                            Eliminar
                                        </a>

                                        <a asp-action="Details" asp-route-id="@evento.EventoId"
                                           class="btn btn-sm btn-outline-secondary rounded-pill px-3">
                                            Detalles
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="mt-3">
                @await Html.PartialAsync("_Pagination", Model, new ViewDataDictionary(ViewData) { { "PaginationAction", "Index" } })
            </div>

        </div>
    </div>

</div>