<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ferias CTP INVU</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        :root {
            --rojo: #BF1D1A;
            --verde: #6A9A2C;
            --amarillo: #F2B705;
            --naranja: #CB6021;
            --bg: #f4f4f4;
            --line: #e5e5e5;
        }

        body {
            background: var(--bg);
        }

        .navbar-ferias {
            background: linear-gradient(90deg, var(--rojo), var(--naranja));
            box-shadow: 0 10px 30px rgba(0,0,0,.08);
        }

            .navbar-ferias .navbar-brand,
            .navbar-ferias .nav-link,
            .navbar-ferias .navbar-toggler {
                color: #fff !important;
            }

            .navbar-ferias .navbar-toggler {
                border-color: rgba(255,255,255,.55);
            }

            .navbar-ferias .navbar-toggler-icon {
                filter: invert(1);
            }

        .chip-navbar {
            color: #fff;
            border: 1px solid rgba(255,255,255,.28);
            background: rgba(255,255,255,.12);
            border-radius: 999px;
            padding: .45rem .75rem;
            font-size: .85rem;
            display: inline-flex;
            align-items: center;
            gap: .45rem;
            white-space: nowrap;
        }

        .btn-logout {
            color: #fff !important;
            border: 1px solid rgba(255,255,255,.28);
            background: rgba(255,255,255,.12);
            border-radius: 999px;
            padding: .45rem .85rem;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: .45rem;
            white-space: nowrap;
        }

            .btn-logout:hover {
                background: rgba(255,255,255,.20);
                border-color: rgba(255,255,255,.45);
            }

        .navbar-ferias .nav-link,
        .navbar-ferias .dropdown-toggle {
            border-radius: 999px;
            padding: .45rem .8rem;
            border: 1px solid rgba(255,255,255,.28);
            background: rgba(255,255,255,.12);
            display: inline-flex;
            align-items: center;
            gap: .45rem;
            white-space: nowrap;
        }

            .navbar-ferias .nav-link:hover,
            .navbar-ferias .dropdown-toggle:hover {
                background: rgba(255,255,255,.20);
                border-color: rgba(255,255,255,.45);
            }

            .navbar-ferias .nav-link.active,
            .navbar-ferias .dropdown-toggle.active {
                background: var(--amarillo);
                color: #111 !important;
                border-color: rgba(0,0,0,.12);
                font-weight: 600;
            }

        .offcanvas-ferias .offcanvas-header {
            background: linear-gradient(90deg, var(--rojo), var(--naranja));
            color: #fff;
        }

        .offcanvas-ferias .btn-close {
            filter: invert(1);
        }

        .offcanvas-ferias .list-group-item {
            border-color: var(--line);
            padding: .9rem .9rem;
            display: flex;
            align-items: center;
            gap: .6rem;
        }

            .offcanvas-ferias .list-group-item:hover {
                background: #f8f9fa;
            }
    </style>
</head>

<body>
    @{
        var rol = Context.Session.GetString("Rol") ?? "";
        var esAdmin = rol.Contains("Administrador", StringComparison.OrdinalIgnoreCase);
        var esCoord = rol.Contains("Coordinador", StringComparison.OrdinalIgnoreCase);
        var esAdminOCoord = esAdmin || esCoord;
        var requiereCambio = Context.Session.GetString("RequiereCambioClave") == "true";
    }

    @if (requiereCambio)
    {
        <script>window.location.href = '@Url.Action("CambiarContrasena", "Account")';</script>
    }
    <header>
        <nav class="navbar navbar-ferias navbar-expand-lg navbar-light">
            <div class="container-fluid">

                <a class="navbar-brand fw-bold d-flex align-items-center gap-2"
                   asp-controller="Inicio" asp-action="Inicio">
                    <span class="d-inline-flex align-items-center justify-content-center"
                          style="width:46px;height:38px;border-radius:12px; padding:4px;">
                        <img src="~/images/logo-invu.png" alt="Logo CTP INVU" style="max-height:100%; width:auto;" />
                    </span>
                    <span>Ferias CTP Invu</span>
                </a>

                <!-- Pantallas pequeñas (solo si está logueado) -->
                @if (!string.IsNullOrEmpty(rol))
                {
                    <button class="navbar-toggler" type="button"
                            data-bs-toggle="offcanvas" data-bs-target="#offcanvasMenu"
                            aria-controls="offcanvasMenu" aria-label="Abrir menú">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                }

                <!-- Para el escritorio -->
                <div class="collapse navbar-collapse d-none d-lg-flex">

                    <ul class="navbar-nav me-auto gap-2">
                        @if (!string.IsNullOrEmpty(rol))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Inicio" asp-action="Inicio">
                                    <i class="bi bi-house"></i> Inicio
                                </a>
                            </li>

                        @if (esAdminOCoord)
                        {
                            <!-- Agrupación: Personas (solo Admin/Coordinador) -->
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-people"></i> Personas
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Usuarios" asp-action="Index"><i class="bi bi-people me-2"></i>Usuarios</a></li>
                                    <li><a class="dropdown-item" asp-controller="Estudiantes" asp-action="Index"><i class="bi bi-mortarboard me-2"></i>Estudiantes</a></li>
                                    <li><a class="dropdown-item" asp-controller="Tutores" asp-action="Index"><i class="bi bi-person-video3 me-2"></i>Tutores</a></li>
                                    <li><a class="dropdown-item" asp-controller="Jueces" asp-action="Index"><i class="bi bi-person-check me-2"></i>Jueces</a></li>
                                </ul>
                            </li>

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button"
                                   data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-gear"></i> Gestión
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Eventos" asp-action="Index"><i class="bi bi-calendar-event me-2"></i>Eventos</a></li>
                                    <li><a class="dropdown-item" asp-controller="CentrosEducativos" asp-action="Index"><i class="bi bi-building me-2"></i>Centros Educativos</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-controller="Categorias" asp-action="Index"><i class="bi bi-tags me-2"></i>Categorías</a></li>
                                    <li><a class="dropdown-item" asp-controller="Subcategorias" asp-action="Index"><i class="bi bi-tag me-2"></i>Subcategorías</a></li>
                                </ul>
                            </li>
                        }

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Inscripciones" asp-action="Index">
                                <i class="bi bi-clipboard-check"></i> Inscripciones
                            </a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button"
                               data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-trophy"></i> Resultados y Reportes
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Resultados" asp-action="Index"><i class="bi bi-trophy me-2"></i>Resultados</a></li>
                                @if (esAdminOCoord)
                                {
                                    <li><a class="dropdown-item" asp-controller="Reportes" asp-action="Index"><i class="bi bi-file-earmark-bar-graph me-2"></i>Reportes</a></li>
                                }
                            </ul>
                        </li>

                            <!-- Perfil (todos los roles) -->
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Usuarios" asp-action="MiPerfil">
                                    <i class="bi bi-person-circle"></i> Perfil
                                </a>
                            </li>
                        }
                    </ul>

                    @if (!string.IsNullOrEmpty(rol))
                    {
                        <!-- Zona derecha -->
                        <div class="d-flex align-items-center gap-2">
                            <span class="chip-navbar">
                                <i class="bi bi-person-badge"></i> Rol: @(rol != "" ? rol : "Usuario")
                            </span>
                            <a class="btn-logout" asp-controller="Account" asp-action="Logout">
                                <i class="bi bi-box-arrow-right"></i> Cerrar sesión
                            </a>
                        </div>
                    }
                </div>
            </div>
        </nav>

        <!-- dispositivos moviles -->
        @if (!string.IsNullOrEmpty(rol))
        {
            <div class="offcanvas offcanvas-start offcanvas-ferias" tabindex="-1" id="offcanvasMenu" aria-labelledby="offcanvasMenuLabel">
                <div class="offcanvas-header">
                    <div class="d-flex align-items-center gap-2">
                        <img src="~/images/logo-invu.png" alt="Logo" style="height:34px;width:auto;border-radius:10px;background:#fff;padding:4px;">
                        <div class="lh-sm">
                            <div class="fw-bold" id="offcanvasMenuLabel">Sistema de Ferias</div>
                            <div class="small opacity-75">CTP Invu Las Cañas</div>
                        </div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Cerrar"></button>
            </div>

            <div class="offcanvas-body">
                <div class="d-flex flex-column gap-2 mb-3">
                    <span class="chip-navbar" style="color:#111;background:#f1f3f5;border-color:#dee2e6">
                        <i class="bi bi-person-badge"></i> Rol: @(rol != "" ? rol : "Usuario")
                    </span>
                    <a class="btn btn-outline-danger w-100 d-flex align-items-center justify-content-center gap-2"
                       asp-controller="Account" asp-action="Logout">
                        <i class="bi bi-box-arrow-right"></i> Cerrar sesión
                    </a>
                </div>

                <div class="list-group">
                    <a class="list-group-item list-group-item-action"
                       asp-controller="Inicio" asp-action="Inicio">
                        <i class="bi bi-house"></i> Inicio
                    </a>

                    @if (esAdminOCoord)
                    {
                        <div class="list-group-item fw-semibold">Personas</div>

                        <a class="list-group-item list-group-item-action"
                           asp-controller="Usuarios" asp-action="Index">
                            <i class="bi bi-people"></i> Usuarios
                        </a>

                        <a class="list-group-item list-group-item-action"
                           asp-controller="Estudiantes" asp-action="Index">
                            <i class="bi bi-mortarboard"></i> Estudiantes
                        </a>

                        <a class="list-group-item list-group-item-action"
                           asp-controller="Tutores" asp-action="Index">
                            <i class="bi bi-person-video3"></i> Tutores
                        </a>

                        <a class="list-group-item list-group-item-action"
                           asp-controller="Jueces" asp-action="Index">
                            <i class="bi bi-person-check"></i> Jueces
                        </a>

                        <div class="list-group-item fw-semibold">Gestión</div>

                        <a class="list-group-item list-group-item-action"
                           asp-controller="Eventos" asp-action="Index">
                            <i class="bi bi-calendar-event"></i> Eventos
                        </a>

                        <a class="list-group-item list-group-item-action"
                           asp-controller="CentrosEducativos" asp-action="Index">
                            <i class="bi bi-building"></i> Centros Educativos
                        </a>

                        <a class="list-group-item list-group-item-action"
                           asp-controller="Categorias" asp-action="Index">
                            <i class="bi bi-tags"></i> Categorías
                        </a>

                        <a class="list-group-item list-group-item-action"
                           asp-controller="Subcategorias" asp-action="Index">
                            <i class="bi bi-tag"></i> Subcategorías
                        </a>
                    }

                    <a class="list-group-item list-group-item-action"
                       asp-controller="Inscripciones" asp-action="Index">
                        <i class="bi bi-clipboard-check"></i> Inscripciones
                    </a>

                    <div class="list-group-item fw-semibold">Resultados y Reportes</div>

                    <a class="list-group-item list-group-item-action"
                       asp-controller="Resultados" asp-action="Index">
                        <i class="bi bi-trophy"></i> Resultados
                    </a>

                    @if (esAdminOCoord)
                    {
                        <a class="list-group-item list-group-item-action"
                           asp-controller="Reportes" asp-action="Index">
                            <i class="bi bi-file-earmark-bar-graph"></i> Reportes
                        </a>
                    }

                    <a class="list-group-item list-group-item-action"
                       asp-controller="Usuarios" asp-action="MiPerfil">
                        <i class="bi bi-person-circle"></i> Perfil
                    </a>
                </div>
            </div>
        </div>
        }
    </header>

    <div class="container-fluid px-3 px-md-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container-fluid px-3 px-md-4">
            &copy; Ferias académicas 2026 - CTP Invu Las Cañas, Alajuela
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        (function () {
            const ruta = (location.pathname || "").toLowerCase();
            document.querySelectorAll("a.nav-link, .dropdown-menu a.dropdown-item, .list-group a").forEach(a => {
                const href = (a.getAttribute("href") || "").toLowerCase();
                if (href && href !== "#" && ruta && (ruta === href || ruta.startsWith(href))) {
                    a.classList.add("active");

                    const dd = a.closest(".dropdown");
                    if (dd) {
                        const toggle = dd.querySelector(".dropdown-toggle");
                        if (toggle) toggle.classList.add("active");
                    }
                }
            });
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>