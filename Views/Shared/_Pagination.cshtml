@using GestionFerias_CTPINVU.Models
@model dynamic

@*
  Vista parcial de paginación reutilizable.
  Uso: @await Html.PartialAsync("_Pagination", Model, new ViewDataDictionary(ViewData) { { "RouteData", routeValues } })
  
  Parámetros esperados en ViewData:
    - "PaginationAction"    : nombre del action (default: "Index")
    - "PaginationController": nombre del controller (opcional, usa el actual)
    - "PaginationRouteData" : IDictionary<string,string?> con parámetros de ruta extra (búsquedas, filtros)
*@

@{
    // Leer metadata de paginación desde el modelo dinámico
    int pageIndex = (int)(Model.GetType().GetProperty("PageIndex")?.GetValue(Model) ?? 1);
    int totalPages = (int)(Model.GetType().GetProperty("TotalPages")?.GetValue(Model) ?? 1);
    int totalCount = (int)(Model.GetType().GetProperty("TotalCount")?.GetValue(Model) ?? 0);
    int pageSize = (int)(Model.GetType().GetProperty("PageSize")?.GetValue(Model) ?? 20);
    bool hasPrev = (bool)(Model.GetType().GetProperty("HasPreviousPage")?.GetValue(Model) ?? false);
    bool hasNext = (bool)(Model.GetType().GetProperty("HasNextPage")?.GetValue(Model) ?? false);

    var action = ViewData["PaginationAction"] as string ?? "Index";
    var extraParams = ViewData["PaginationRouteData"] as Dictionary<string, string?> ?? new();

    int showing = Math.Min(pageIndex * pageSize, totalCount);
    int from = totalCount == 0 ? 0 : (pageIndex - 1) * pageSize + 1;

    // Calcular rango de páginas a mostrar (máx 5 botones)
    int pagWindowStart = Math.Max(1, pageIndex - 2);
    int pagWindowEnd = Math.Min(totalPages, pagWindowStart + 4);
    if (pagWindowEnd - pagWindowStart < 4) pagWindowStart = Math.Max(1, pagWindowEnd - 4);

    // Función helper para construir route values con página
    Dictionary<string, string?> BuildRoute(int page)
    {
        var r = new Dictionary<string, string?>(extraParams) { ["pagina"] = page.ToString() };
        return r;
    }
}

@if (totalPages > 1 || totalCount > 0)
{
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;margin-top:16px;padding:10px 4px;">

        <!-- Info de registros -->
        <span style="font-size:13px;color:#666;">
            Mostrando <strong>@from</strong>–<strong>@showing</strong> de <strong>@totalCount</strong> registro@(totalCount != 1 ? "s" : "")
        </span>

        @if (totalPages > 1)
        {
            <nav aria-label="Paginación">
                <ul style="display:flex;list-style:none;margin:0;padding:0;gap:4px;flex-wrap:wrap;">

                    <!-- Anterior -->
                    <li>
                        @if (hasPrev)
                        {
                            <a asp-action="@action" asp-all-route-data="@BuildRoute(pageIndex - 1)"
                               style="display:inline-flex;align-items:center;padding:6px 12px;border-radius:10px;border:1px solid #e5e5e5;background:#fff;font-size:13px;text-decoration:none;color:#333;">
                                <i class="bi bi-chevron-left" style="font-size:11px;"></i>
                            </a>
                        }
                        else
                        {
                            <span style="display:inline-flex;align-items:center;padding:6px 12px;border-radius:10px;border:1px solid #e5e5e5;background:#f5f5f5;font-size:13px;color:#bbb;cursor:not-allowed;">
                                <i class="bi bi-chevron-left" style="font-size:11px;"></i>
                            </span>
                        }
                    </li>

                    <!-- Primera página si estamos lejos -->
                    @if (pagWindowStart > 1)
                    {
                        <li>
                            <a asp-action="@action" asp-all-route-data="@BuildRoute(1)"
                               style="display:inline-flex;align-items:center;padding:6px 11px;border-radius:10px;border:1px solid #e5e5e5;background:#fff;font-size:13px;text-decoration:none;color:#333;">1</a>
                        </li>
                        @if (pagWindowStart > 2)
                        {
                            <li><span style="display:inline-flex;align-items:center;padding:6px 8px;font-size:13px;color:#999;">…</span></li>
                        }
                    }

                    <!-- Ventana de páginas -->
                    @for (int i = pagWindowStart; i <= pagWindowEnd; i++)
                    {
                        var iPage = i;
                        if (iPage == pageIndex)
                        {
                            <li>
                                <span style="display:inline-flex;align-items:center;padding:6px 11px;border-radius:10px;border:1px solid transparent;background:#BF1D1A;color:#fff;font-size:13px;font-weight:600;">@iPage</span>
                            </li>
                        }
                        else
                        {
                            <li>
                                <a asp-action="@action" asp-all-route-data="@BuildRoute(iPage)"
                                   style="display:inline-flex;align-items:center;padding:6px 11px;border-radius:10px;border:1px solid #e5e5e5;background:#fff;font-size:13px;text-decoration:none;color:#333;">@iPage</a>
                            </li>
                        }
                    }

                    <!-- Última página si estamos lejos -->
                    @if (pagWindowEnd < totalPages)
                    {
                        @if (pagWindowEnd < totalPages - 1)
                        {
                            <li><span style="display:inline-flex;align-items:center;padding:6px 8px;font-size:13px;color:#999;">…</span></li>
                        }
                        <li>
                            <a asp-action="@action" asp-all-route-data="@BuildRoute(totalPages)"
                               style="display:inline-flex;align-items:center;padding:6px 11px;border-radius:10px;border:1px solid #e5e5e5;background:#fff;font-size:13px;text-decoration:none;color:#333;">@totalPages</a>
                        </li>
                    }

                    <!-- Siguiente -->
                    <li>
                        @if (hasNext)
                        {
                            <a asp-action="@action" asp-all-route-data="@BuildRoute(pageIndex + 1)"
                               style="display:inline-flex;align-items:center;padding:6px 12px;border-radius:10px;border:1px solid #e5e5e5;background:#fff;font-size:13px;text-decoration:none;color:#333;">
                                <i class="bi bi-chevron-right" style="font-size:11px;"></i>
                            </a>
                        }
                        else
                        {
                            <span style="display:inline-flex;align-items:center;padding:6px 12px;border-radius:10px;border:1px solid #e5e5e5;background:#f5f5f5;font-size:13px;color:#bbb;cursor:not-allowed;">
                                <i class="bi bi-chevron-right" style="font-size:11px;"></i>
                            </span>
                        }
                    </li>

                </ul>
            </nav>
        }
    </div>
}
